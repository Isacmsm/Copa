@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Arquivo";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}



@functions {
    string acao = null;
    string extencoesValidas = ".pdf,.jpg,.txt,.docx";
    HttpPostedFileBase arquivo = null;
    string nomeArquivo = null;

    private void AlimentarVariaveis()
    {
        acao = Util.ChecaNulo(Request.Form["acao"]);
        nomeArquivo = Util.ChecaNulo(Request.Form["nomeArquivo"]);
        if (Request.Files.Count > 0)
        {
            arquivo = Request.Files["arquivo"];
        }
    }

    private string IsInvalid(string key)
    {
        return !ModelState.IsValidField(key) ? "is-invalid" : "";
    }

    private void SalvarArquivo()
    {
        if (arquivo == null)
        {
            throw new InvalidOperationException("Anexe o arquivo");
        }
        if (string.IsNullOrWhiteSpace(arquivo.FileName))
        {
            throw new InvalidOperationException("Não foi possivel identificar o nome do arquivo!");
        }

        if (arquivo.ContentLength > 512 * 1000)
        {
            ModelState.AddError("arquivo", "Arquivo deve ter o tamanho de até 512KB");
            return;
        }
        if (!Directory.Exists(Server.MapPath("arquivos")))
        {
            Directory.CreateDirectory(Server.MapPath("arquivos"));
        }

        string caminhoArquivo = Path.Combine(Server.MapPath("arquivos"), arquivo.FileName);

        arquivo.SaveAs(caminhoArquivo);
    }

    private void ExcluirArquivo()
    {
        if (nomeArquivo != null)
        {
            string caminhoArquivo = Path.Combine(Server.MapPath("arquivos"), nomeArquivo);

            if (File.Exists(caminhoArquivo))
            {
                File.Delete(caminhoArquivo);
            }
        }
    }
}

@{
    AlimentarVariaveis();

    if (acao == "I")
    {
        Util.ExceptionHandler(() =>
        {
            SalvarArquivo();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
        }, this.ModelState);
    }

    if (acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            ExcluirArquivo();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
        }, this.ModelState);
    }
}



@section head {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <meta charset="UTF-8">
}

<body>
    <form name="form1" method="post" enctype="multipart/form-data">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="nomeArquivo" id="nomeArquivo" />

        <div class="container">
            <h1>Anexar Arquivos</h1>
            @PageHelper.MakeAlert()

            <div class="nt-5">
                <div class="row">
                    <div class="col">
                        <input type="file" id="arquivo" name="arquivo" class="form-control @IsInvalid("arquivo")" onchange="checkFile(this)" />
                        @PageHelper.MakeFeedBack("arquivo")
                    </div>

                    <div class="col-auto">
                        <button type="button" class="btn btn-sm btn-primary" onclick="enviar()">Enviar arquivo</button>
                    </div>
                </div>
                <div class="mt-3">
                    <div class="small text-muted">Extenções válidas: @extencoesValidas</div>
                    <div class="small text-muted">Tamanho do máximo do arquivo: 512kb</div>
                </div>
            </div>

            @{
                if (Directory.Exists(Server.MapPath("arquivos")))
                {
                    string[] arquivos = Directory.GetFiles(Server.MapPath("arquivos"));

                    if (arquivos != null && arquivos.Length > 0)
                    {
                        <div class="card mt-3">
                            <div class="card-header">
                                Arquivos baixados
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (string item in arquivos)
                                {
                                    <div class="list-group-item list-group-flush">
                                        <div class="row">
                                            <div class="col">@Path.GetFileName(item)</div>
                                            <div class="col-auto">
                                                <a href="~/AreaRestrita/arquivos/@Path.GetFileName(item)" target="_blank">Baixar</a>
                                                <a href="javascript:void(0)" onclick="excluirArquivo('@Path.GetFileName(item)')">Excluir</a>
                                            </div>
                                        </div>
                                    </div>
                                }

                            </div>
                        </div>
                    }
                }
            }

        </div>
    </form>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function checkFile(input) {
            const extencoesValidas = "@extencoesValidas".toLocaleUpperCase().split(",");
            const extencaoArquivo = input.value.substring(input.value.lastIndexOf("."));

            if (extencoesValidas.indexOf(extencaoArquivo.toLocaleUpperCase()) < 0) {
                alert("Formato de arquivo invalido. Extenções aceitas: " + extencoesValidas);
                input.value = "";
                return false
            }
            return true
        }

        function enviar() {
            var arquivos = document.form1.arquivo.value;

            if (!arquivo) {
                alert("Anexe o arquivo!")
                return;
            }
            document.form1.acao.value = "I";
            document.form1.submit();
        }

        function excluirArquivo(nomeArquivo) {
            document.form1.acao.value = "E";
            document.form1.nomeArquivo.value = nomeArquivo;
            document.form1.submit();
        }
    </script>
</body>

