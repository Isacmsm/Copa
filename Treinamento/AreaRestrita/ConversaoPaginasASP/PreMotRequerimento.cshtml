@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Arquivo - Educacao";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {
    private enum View
    {
        Index,
        New,
        Edit
    }
    private class PreMotivoRequerimento
    {
        public string IdPreMovitovRequerimento { get; set; }
        public string Descricao { get; set; }
        public string Chave { get; set; }
    }
    string acao = null;

    string idSessao = null;
    string idPreMotivoRequerimento = null;
    string chave = null;
    string descricao = null;
    List<PreMotivoRequerimento> preMotivosRequerimento = null;
    View view = View.Index;
    List<Botao> botoes = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecarNulo(Request.Form["acao"]);
        idSessao = Session["idSessao"].ToString();

        botoes = new BotaoDao().GetAll();

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }
    }

    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@idSessao", idSessao);
        parametros.Add("@IdPreMotivoRequerimento", idPreMotivoRequerimento);


        new Dao().ExecutarAcao(acao, parametros);
    }
    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@idSessao", idSessao);
        parametros.Add("@IdPreMotivoRequerimento", idPreMotivoRequerimento);

        preMotivosRequerimento = new Dao().ExecutarAcaoList<PreMotivoRequerimento>("C", parametros);
    }

    private void LimpaVariaveis()
    {
        acao = null;
        idSessao = null;
        idPreMotivoRequerimento = null;
        chave = null;
        descricao = null;

    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && preMotivosRequerimento != null && preMotivosRequerimento.Count == 1)
        {
            PreMotivoRequerimento preMotivoRequerimento = preMotivosRequerimento.FirstOrDefault();
            idPreMotivoRequerimento = preMotivoRequerimento.IdPreMovitovRequerimento;
            descricao = preMotivoRequerimento.Descricao;
            chave = preMotivoRequerimento.Chave;
        }
    }
}

@{

    AlimentaVariaveis();

    if (acao == "I" || acao == "E" || acao == "A")
    {
        Util.ExceptionHandler(() =>
        {
            Manutencao();
            view = View.Index;
            LimpaVariaveis();

            ModelState.AddError("alert-success", "Operaçăo realizada com sucesso");
        }, this.ModelState);
    }

    Util.ExceptionHandler(() =>
    {
        Consultar();
        CarregarDados();
    }, this.ModelState);

}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idPreMotivoRequerimento" id="idPreMotivoRequerimento" value="@idPreMotivoRequerimento" />

        <div class="container">

            @PageHelper.MakeAlert()

            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>

            @if (view == View.New)
            {
                @PageHelper.MakeBotao(botoes, "I");
            }

            @if (view == View.Edit)
            {
                @PageHelper.MakeBotao(botoes, "A");

            }

            @if (view == View.New || view == View.Edit)
            {
                <div class=" mb-3">
                    <label class="form-label mt-3" for="chave">Chave</label>
                    <input class="form-control @Util.IsInvalid(ModelState, "chave")" type="text" name="chave" id="chave" size="3" value="@chave" maxlength="1" @(view == View.Edit ? "readonly" : "") />
                    @PageHelper.MakeFeedBack("chave")

                    <label class="form-label mt-3" for="descricao">Descriçăo</label>
                    <input class="form-control @Util.IsInvalid(ModelState, "descricao")" type="text" name="descricao" id="descricao" value="@descricao" />
                    @PageHelper.MakeFeedBack("descricao")

                </div>
            }
            else if (view == View.Index)
            {
                if (botoes.Any(x => x.Codigo == "I"))
                {
                    <button class="btn btn-secondary" type="button" onclick="adicionarNovo()">Novo</button>
                }

                if (preMotivosRequerimento != null)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Chave</th>
                                <th>Descricao</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (PreMotivoRequerimento item in preMotivosRequerimento)
                            {
                                <tr onclick="editar('@item.IdPreMovitovRequerimento')">
                                    <td>@item.Chave</td>
                                    <td>@item.Descricao</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    </form>
</body>
<script src="~/Scripts/Scripts.js"></script>
<script>
    function editar(idPreMovimentoRequerimento) {
        document.form1.view.value = "@((int)View.Edit)";
        document.form1.IdPreMotivoRequerimento.value = idPreMovimentoRequerimento;
        executaAcao('C');
    }
    function adicionarNovo() {
        document.form1.view.value = "@((int)View.New)";
        executaAcao('');
    }
</script>