@{
    Page.Title = "Modulos";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {
    private enum View
    {
        Index,
        New,
        Edit
    }
    private class Modulo
    {
        public string IdModulo { get; set; }
        public string IdSistema { get; set; }
        public string Sistema { get; set; }
        public string Codigo { get; set; }
        public string Caption { get; set; }

    }

    private class Sistema
    {
        public string IdSistema { get; set; }
        public string Caption { get; set; }
    }

    string acao = null;
    string idModulo = null;
    string idSistema = null;
    string codigo = null;
    string caption = null;

    View view = View.Index;

    List<Modulo> modulos = new List<Modulo>();
    List<Sistema> sistemas = new List<Sistema>();

    private void AlimentaVariaveis()
    {
        acao = Util.ChecarNulo(Request.Form["acao"]);
        idModulo = Util.ChecarNulo(Request.Form["idModulo"]);
        idSistema = Util.ChecarNulo(Request.Form["idSistema"]);
        codigo = Util.ChecarNulo(Request.Form["codigo"]);
        caption = Util.ChecarNulo(Request.Form["caption"]);
        
        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }

    }
    private void LimpaVariaveis()
    {
        acao = null;
        idModulo = null;
        idSistema = null;
        codigo = null;
        caption = null;
    }

    private void ConsultarModulos()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdModulo", idModulo);

        string procedure = GetNomeProcedure("C");

        Dao dao = new Dao();
        modulos = dao.ExecutarProcedureList<Modulo>(procedure, parametros);
    }
    private void ConsultarSistemas()
    {
        string procedure = GetNomeProcedure("C");
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", "1");

        Dao dao = new Dao();
        sistemas = dao.ExecutarProcedureList<Sistema>(procedure, parametros);
    }

    private string GetNomeProcedure(string acao)
    {
        switch (acao)
        {
            case "C": return "stp_Das_Modulo_Sel";
            case "I": return "stp_Das_Modulo_Ins";
            case "A": return "stp_Das_Modulo_Upd";
            case "E": return "stp_Das_Modulo_Del";
            default: return null;
        }
    }
    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdModulo", idModulo);
        parametros.Add("@Codigo", codigo);
        parametros.Add("@Caption", caption);
        parametros.Add("@IdSistema", idSistema);

        string procedure = GetNomeProcedure(acao);

        Dao dao = new Dao();
        dao.ExecutarProcedure(procedure, parametros);
    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && modulos != null && modulos.Count == 1)
        {
            Modulo modulo = modulos.FirstOrDefault();
            idModulo = modulo.IdModulo;
            idSistema = modulo.IdSistema;
            codigo = modulo.Codigo;
            caption = modulo.Caption;
        }
    }
}

@{

    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            Manutencao();
            view = View.Index;
            LimpaVariaveis();

            ModelState.AddError("alert-success", "Operação realizada com sucesso");
        }, this.ModelState);
    }

    Util.ExceptionHandler(() =>
    {
        ConsultarSistemas();
        ConsultarModulos();
        CarregarDados();

    }, this.ModelState);
}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idModulo" id="idModulo" value="@idModulo" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">
            @RenderPage("~/AreaRestrita/Menu.cshtml")

            <h1>Módulos</h1>

            @PageHelper.MakeAlert()

            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>
            @if (view == View.Index)
            {
                <button class="btn btn-secondary" type="button" onclick="novo()">Novo</button>
            }

            @if (view == View.New)
            {
                <button class="btn btn-secondary" type="button" onclick="executaAcao('I')">Incluir</button>
            }

            @if (view == View.Edit)
            {
                <button class="btn btn-secondary" type="button" onclick="executaAcao('A')">Alterar</button>
                <button class="btn btn-secondary" type="button" onclick="executaAcao('E')">Excluir</button>
            }

            @if (view == View.New || view == View.Edit)
            {
                <div class="mt-3 mb-3">
                    <label class="form-label mt-3" for="jogador">Código</label>
                    <input class="form-control @Util.IsInvalid(ModelState, "codigo")" type="text" name="codigo" id="codigo" value="@codigo" />
                    @PageHelper.MakeFeedBack("codigo")

                    <label class="form-label mt-3" for="caption">Caption</label>
                    <input class="form-control @Util.IsInvalid(ModelState, "caption")" type="text" name="caption" id="caption" value="@caption" />
                    @PageHelper.MakeFeedBack("caption")
                </div>

                <div class="mt-3 mb-3">
                    <label class="form-label" for="idSistema">Sistema</label>
                    <select class="form-control @Util.IsInvalid(ModelState,"sistema")" id="sistema" name="sistema">
                        <option value=""></option>
                        @if (sistemas != null)
                        {
                            foreach (Sistema item in sistemas)
                            {
                                <option value="@item.IdSistema" @(item.IdSistema == idSistema ? "selected" : "")>@item.Caption</option>
                            }
                        }
                    </select>
                    @PageHelper.MakeFeedBack("sistema")
                </div>

            }

            @if (view == View.Index)
            {
                if (modulos != null)
                {
                    <table class="table mt-3">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Caption</th>
                                <th>Sistema</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Modulo item in modulos)
                            {
                                <tr>
                                    <td>@item.Codigo</td>
                                    <td>@item.Caption</td>
                                    <td>@item.Sistema</td>
                                    <td><button class="btn btn-secondary" type="button" onclick="editar('@item.IdModulo')">Editar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }

        </div>
    </form>

    <script src="~/Scripts/Scripts.js"></script>
    <script>
        function editar(idModulo) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idModulo.value = idModulo;
            executaAcao('C');
        }
        function novo() {
            document.form1.view.value = "@((int)View.New)";
            executaAcao('');
        }
    </script>
</body>