@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Times";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}



@functions {
    private enum View
    {
        Index,
        New,
        Edit
    }

    //Definindo a Classe Time
    private class Time
    {
        // e suas propiedades (todo Objeto Time tem um IdTime e um Nome.
        public string IdTime { get; set; }
        public string Nome { get; set; }

    }



    string acao = null;
    List<Botao> botoes = null;
    string idTime = null;
    Time time = null;
    View view = View.Index;
    List<Time> times = null;
    string idSessao = null;

    // vai capturar os valores das variaveis submetida no forms e alimentar suas respectivas variaveis
    private void AlimentaVariaveis()
    {
        acao = Util.ChecaNulo(Request.Form["acao"]);
        idTime = Util.ChecaNulo(Request.Form["idTime"]);
        botoes = new BotaoDao().GetAll();
        idSessao = Convert.ToString(Session["idSessao"]);

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }
    }

    //Metodo invocado após a manutenção paral limpar os valores das variáveis que estão na memoria do servidor.
    private void LimparVariaveis()
    {
        acao = null;
        idTime = null;
        time = null;

    }

    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdTime", idTime);

        times = new Dao().ExecutarAcaoList<Time>("C", parametros);
    }





    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }

    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdTime", idTime);
        parametros.Add("@Nome", time.Nome);
        parametros.Add("@IdSessao", idSessao);

        new Dao().ExecutarAcao(acao, parametros);

    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && times != null && times.Count == 1)
        {
            time = times.FirstOrDefault();
        }
    }


}

@{
    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            time = new Time()
            {
                IdTime = Util.ChecaNulo(Request.Form["idTime"]),
                Nome = Util.ChecaNulo(Request.Form["nome"])
            };

            Manutencao();
            LimparVariaveis();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
            view = View.Index;
        }, this.ModelState);

    }



    Util.ExceptionHandler(() =>
    {
        Consultar();
        CarregarDados();
    }, this.ModelState);



    if (time == null)
    {
        time = new Time();
    }






}

@section head {

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idTime" id="idTime" value="@idTime" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">

            <div class="row g-3">
                <div>
                    @RenderPage("~/AreaRestrita/Menu.cshtml")
                </div>
                <div>
                    <h1>Time</h1>
                </div>


                @if (view == View.Edit || view == View.New)
                {
                    <div class="col-12 mb-3">
                        @PageHelper.MakeAlert()
                    </div>

                    <div class="col-md-4">
                        <input class="form-control @IsInvalid("nome")" placeholder="Nome" type="text" name="nome" id="nome" value="@time.Nome" />
                        @PageHelper.MakeFeedBack("nome")
                    </div>


                    <div class="col-md-4">
                        <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()"><i class="bi bi-eraser-fill"></i> Limpar</button>
                    </div>

                }

                @if (view == View.Index)
                {
                    if (botoes.Any(x => x.Codigo == "I"))
                    {
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-primary btn-sm" type="submit" onclick="novo()"><i class="bi bi-file-earmark-plus"></i> Novo</button>
                        </div>
                    }
                }

                @if (view == View.New || view == View.Edit)
                {
                    <div class="col-12 mb-5">
                        @if (view == View.New)
                        {
                            @PageHelper.MakeBotao(botoes, "I")

                        }
                        @if (view == View.Edit)
                        {
                            @PageHelper.MakeBotao(botoes, "A")
                            @PageHelper.MakeBotao(botoes, "E")
                        }
                    </div>
                }
            </div>



            @if (view == View.Index)
            {
                //se a lista de times não estiver vazia ele vai criar a tabela dos times no site
                if (times != null)
                {
                    <div>
                        <table class="table table-striped rounded mb-0">
                            <colgroup>
                                <col style="width: 10%" />
                                <col style="width: 50%" />
                                <col style="width: 10%" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="text-center align-middle" scope="col">Id</th>
                                    <th scope="col">Nome</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody class="table-group-divider">
                                <!-- vai pecorrer todos os itens da lista times e vai criar uma coluna da tabela para cada Time com as suas propiedades -->
                                @foreach (Time item in times)
                                {
                                    <tr>
                                        <td class="text-center align-middle">#@item.IdTime </td>
                                        <td>@item.Nome</td>
                                        <td class="text-center align-middle">
                                            @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                            {
                                                <button class="btn btn-warning btn-sm" type="button" onclick="editar('@item.IdTime')"><i class="bi bi-pencil-square"></i> Editar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            }


        </div>
    </form>

    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // aqui depois do botão (html) gerar o evento que foi capturado pela função do Js ele vai definir o valor de acao no forms ( Js alterando o HTML)

        // recebe as informações do html, ao capturar o evento onclick, e altera o estado do html do forms para ser depois capturado pelo servidor
        function editar(idTime) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idTime.value = idTime;
            executarAcao('C');
        }

        function novo() {
            document.form1.view.value = "@((int)View.New)";
            document.form1.submit();
        }
    </script>


</body>


