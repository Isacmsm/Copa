@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Confrontos";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {

    private class TimeConfronto
    {
        public string IdTime1 { get; set; }
        public string NomeTime1 { get; set; }
        public string IdTime2 { get; set; }
        public string NomeTime2 { get; set; }
        public string TemJogo { get; set; }
    }

    private class Jogo
    {
        public string IdJogo { get; set; }
        public string IdTime1 { get; set; }
        public string NomeTime1 { get; set; }
        public string IdTime2 { get; set; }
        public string NomeTime2 { get; set; }
        public string Placar1 { get; set; }
        public string Placar2 { get; set; }
        public string DataInicio { get; set; }
        public string HoraInicio { get; set; }
        public string DataFinal { get; set; }
        public string HoraFinal { get; set; }
        public string JaIniciou { get; set; }
        public string TemPlacar { get; set; }
    }

    string acao = null;
    List<TimeConfronto> confrontos = new List<TimeConfronto>();
    string idTime1 = null;
    string idTime2 = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecaNulo(Request.Form["acao"]);
        idTime1 = Util.ChecaNulo(Request.Form["idTime1"]);
        idTime2 = Util.ChecaNulo(Request.Form["idTime2"]);
    }

    private void ConsultarConfrontos()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", "Confronto");

        confrontos = new Dao().ExecutarProcedureList<TimeConfronto>("stp_ConsultaConfrontos_Sel", parametros);
    }

    private void CriarJogos(string jogosJson)
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@JogosJson", jogosJson);
        parametros.Add("@Tipo", "I");

        new Dao().ExecutarProcedure("stp_ManutencaoConfrontos", parametros);
    }

    private void ExcluirJogos(string jogosJson)
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@JogosJson", jogosJson);
        parametros.Add("@Tipo", "E");

        new Dao().ExecutarProcedure("stp_ManutencaoConfrontos", parametros);
    }

    private void ConsultarJogos()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", "Jogos");
        parametros.Add("@idTime1", idTime1);
        parametros.Add("@idTime2", idTime2);

        var jogos = new Dao().ExecutarProcedureList<Jogo>("stp_ConsultaConfrontos_Sel", parametros);

        Response.ContentType = "application/json";
        Response.Write(new System.Web.Script.Serialization.JavaScriptSerializer().Serialize(jogos));
        Response.End();
    }
}

@{
    AlimentaVariaveis();

    if (acao == "I")
    {
        Util.ExceptionHandler(() =>
        {
            string jogosJson = Util.ChecaNulo(Request.Form["jogosJson"]);
            CriarJogos(jogosJson);
            ModelState.AddError("alert-success", "Jogos criados com sucesso");
        }, this.ModelState);
    }

    if (acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            string jogosJson = Util.ChecaNulo(Request.Form["jogosJson"]);
            ExcluirJogos(jogosJson);
            ModelState.AddError("alert-success", "Jogos excluídos com sucesso");
        }, this.ModelState);
    }

    if (acao == "CJ")
    {
        ConsultarJogos();
    }

    Util.ExceptionHandler(ConsultarConfrontos, this.ModelState);

    var timeIds = confrontos.Select(p => p.IdTime1).Distinct().ToList();
    var nomeTime = confrontos.GroupBy(p => p.IdTime1).ToDictionary(g => g.Key, g => g.First().NomeTime1);
}

@section head {
    <style>
        .celula-verde {
            background-color: #90EE90 !important;
            cursor: pointer;
        }

        .celula-vermelha {
            background-color: #F08080 !important;
            cursor: pointer;
        }

            .celula-verde:hover, .celula-vermelha:hover {
                opacity: 0.7;
            }

        .diagonal {
            background-color: #6c757d !important;
            cursor: default;
        }
    </style>
}

<div class="container">
    <div class="row g-3">
        <div>
            @RenderPage("~/AreaRestrita/Menu.cshtml")
        </div>
        <div>
            <h1>Confrontos - Edição Visual</h1>
        </div>
        <div class="col-12">
            @PageHelper.MakeAlert()
        </div>
    </div>


    <div class="mb-3">
        <span class="badge" style="background-color: #90EE90; color: #000;">&#9632;</span> Com jogo
        <span class="badge ms-2" style="background-color: #F08080; color: #000;">&#9632;</span> Sem jogo
    </div>


    <div class="table-responsive">
        <table class="table table-bordered text-center">
            <thead>
                <tr>
                    <th>Times</th>
                    @foreach (string id in timeIds)
                    {
                        <th>@nomeTime[id]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (string linha in timeIds)
                {
                    <tr>
                        <td class="fw-bold">@nomeTime[linha]</td>
                        @foreach (string coluna in timeIds)
                        {
                            if (linha == coluna)
                            {
                                <td class="diagonal"></td>
                            }
                            else
                            {
                                TimeConfronto par = confrontos.FirstOrDefault(p =>
                                    p.IdTime1 == linha && p.IdTime2 == coluna);

                                string classe = par != null && par.TemJogo == "1"
                                    ? "celula-verde"
                                    : "celula-vermelha";

                                <td class="@classe"
                                    data-time1="@linha"
                                    data-time2="@coluna"
                                    data-nometime1="@nomeTime[linha]"
                                    data-nometime2="@nomeTime[coluna]"
                                    data-original="@(par?.TemJogo ?? "0")"
                                    onclick="toggleCelula(this)">
                                </td>
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>


    <div class="mt-3">
        <button type="button" class="btn btn-primary" onclick="abrirConfirmacao()">
            <i class="bi bi-check-lg"></i> Registrar Alterações
        </button>
        <a href="Jogo.cshtml" class="btn btn-secondary ms-2">Voltar</a>
    </div>
</div>


<div class="modal fade" id="modalCriar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar Criação de Jogos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="listaCriar"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="gravarCriacao()">Gravar</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalExcluir" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar Exclusão de Jogos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="listaExcluir"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" onclick="gravarExclusao()">Excluir</button>
            </div>
        </div>
    </div>
</div>

<form id="formAcao" method="post" style="display:none;">
    <input type="hidden" name="acao" id="acao" />
    <input type="hidden" name="jogosJson" id="jogosJson" />
</form>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script>

    var modalCriar;
    var modalExcluir;

    $(document).ready(function () {
        modalCriar = new bootstrap.Modal(document.getElementById("modalCriar"));
        modalExcluir = new bootstrap.Modal(document.getElementById("modalExcluir"));
    });

    function toggleCelula(celula) {
        var time1 = $(celula).data("time1");
        var time2 = $(celula).data("time2");
        var espelho = $('td[data-time1="' + time2 + '"][data-time2="' + time1 + '"]');

        if ($(celula).hasClass("celula-verde")) {
            $(celula).removeClass("celula-verde").addClass("celula-vermelha");
            espelho.removeClass("celula-verde").addClass("celula-vermelha");
        } else {
            $(celula).removeClass("celula-vermelha").addClass("celula-verde");
            espelho.removeClass("celula-vermelha").addClass("celula-verde");
        }
    }

    function coletarAlteracoes() {
        var criar = [];
        var excluir = [];
        var processados = [];

        $("td[data-time1]").each(function () {
            var time1 = $(this).data("time1").toString();
            var time2 = $(this).data("time2").toString();
            var original = $(this).data("original").toString();
            var parChave = [time1, time2].sort().join("-");

            if (processados.indexOf(parChave) >= 0) return;
            processados.push(parChave);

            var estaVerde = $(this).hasClass("celula-verde");
            var eraVerde = original === "1";

            if (estaVerde && !eraVerde) {
                criar.push({
                    idTime1: time1,
                    idTime2: time2,
                    nomeTime1: $(this).data("nometime1"),
                    nomeTime2: $(this).data("nometime2")
                });
            } else if (!estaVerde && eraVerde) {
                excluir.push({
                    idTime1: time1,
                    idTime2: time2,
                    nomeTime1: $(this).data("nometime1"),
                    nomeTime2: $(this).data("nometime2")
                });
            }
        });

        return { criar: criar, excluir: excluir };
    }

    function abrirConfirmacao() {
        var alteracoes = coletarAlteracoes();

        if (alteracoes.criar.length === 0 && alteracoes.excluir.length === 0) {
            alert("Nenhuma alteração foi feita.");
            return;
        }

        if (alteracoes.criar.length > 0) {
            var html = '<table class="table table-bordered">';
            html += '<thead><tr><th>Confronto</th><th>Data Início</th><th>Hora Início</th><th>Data Final</th><th>Hora Final</th></tr></thead><tbody>';

            for (var i = 0; i < alteracoes.criar.length; i++) {
                var c = alteracoes.criar[i];
                html += '<tr>';
                html += '<td>' + c.nomeTime1 + ' x ' + c.nomeTime2 + '</td>';
                html += '<td><input type="date" class="form-control form-control-sm" name="dataInicio_' + i + '" required /></td>';
                html += '<td><input type="time" class="form-control form-control-sm" name="horaInicio_' + i + '" step="1" required /></td>';
                html += '<td><input type="date" class="form-control form-control-sm" name="dataFinal_' + i + '" required /></td>';
                html += '<td><input type="time" class="form-control form-control-sm" name="horaFinal_' + i + '" step="1" required /></td>';
                html += '</tr>';
            }
            html += '</tbody></table>';

            $("#listaCriar").html(html);
            modalCriar.show();
        }

        if (alteracoes.excluir.length > 0) {
            buscarJogosParaExcluir(alteracoes.excluir);
        }
    }

    function buscarJogosParaExcluir(pares) {
        var promises = [];

        for (var i = 0; i < pares.length; i++) {
            var p = pares[i];
            promises.push(
                $.ajax({
                    type: "POST",
                    url: "JogoConfronto.cshtml",
                    data: { acao: "CJ", idTime1: p.idTime1, idTime2: p.idTime2 }
                })
            );
        }

        $.when.apply($, promises).done(function () {
            var todosJogos = [];
            var resultados = promises.length === 1 ? [arguments] : arguments;

            for (var i = 0; i < resultados.length; i++) {
                var jogos = typeof resultados[i][0] === "string"
                    ? JSON.parse(resultados[i][0])
                    : resultados[i][0];

                for (var j = 0; j < jogos.length; j++) {
                    todosJogos.push(jogos[j]);
                }
            }

            montarModalExclusao(todosJogos);
        });
    }

    function montarModalExclusao(jogos) {
        var html = '<table class="table table-bordered">';
        html += '<thead><tr>';
        html += '<th><input type="checkbox" id="checkTodos" checked /></th>';
        html += '<th>ID</th><th>Confronto</th><th>Placar</th><th>Início</th><th>Status</th>';
        html += '</tr></thead><tbody>';

        for (var i = 0; i < jogos.length; i++) {
            var j = jogos[i];
            var jaIniciou = j.JaIniciou === "1";
            var temPlacar = j.TemPlacar === "1";
            var status = "";

            if (temPlacar) {
                status = '<span class="badge bg-danger">Possui placar</span>';
            } else if (jaIniciou) {
                status = '<span class="badge bg-warning text-dark">Já iniciou</span>';
            } else {
                status = '<span class="badge bg-success">Pode excluir</span>';
            }

            var disabled = (jaIniciou || temPlacar) ? 'disabled' : '';

            html += '<tr class="' + (disabled ? 'table-danger' : '') + '">';
            html += '<td><input type="checkbox" class="checkJogo" value="' + j.IdJogo + '" ' + (disabled ? '' : 'checked') + ' ' + disabled + ' /></td>';
            html += '<td>#' + j.IdJogo + '</td>';
            html += '<td>' + j.NomeTime1 + ' x ' + j.NomeTime2 + '</td>';
            html += '<td>' + (j.Placar1 || '0') + ' x ' + (j.Placar2 || '0') + '</td>';
            html += '<td>' + j.DataInicio + ' ' + j.HoraInicio + '</td>';
            html += '<td>' + status + '</td>';
            html += '</tr>';
        }
        html += '</tbody></table>';

        $("#listaExcluir").html(html);

        $("#checkTodos").on("change", function () {
            $(".checkJogo:not(:disabled)").prop("checked", $(this).prop("checked"));
        });

        modalExcluir.show();
    }

    function gravarCriacao() {
        var alteracoes = coletarAlteracoes();
        var jogos = [];

        for (var i = 0; i < alteracoes.criar.length; i++) {
            var c = alteracoes.criar[i];
            jogos.push({
                idTime1: c.idTime1,
                idTime2: c.idTime2,
                dataInicio: $('input[name="dataInicio_' + i + '"]').val(),
                horaInicio: $('input[name="horaInicio_' + i + '"]').val(),
                dataFinal: $('input[name="dataFinal_' + i + '"]').val(),
                horaFinal: $('input[name="horaFinal_' + i + '"]').val()
            });
        }

        for (var i = 0; i < jogos.length; i++) {
            if (!jogos[i].dataInicio || !jogos[i].horaInicio || !jogos[i].dataFinal || !jogos[i].horaFinal) {
                alert("Preencha todos os campos de data e hora.");
                return;
            }
        }

        $("#acao").val("I");
        $("#jogosJson").val(JSON.stringify(jogos));
        $("#formAcao").submit();
    }

    function gravarExclusao() {
        var ids = [];
        $(".checkJogo:checked").each(function () {
            ids.push($(this).val());
        });

        if (ids.length === 0) {
            alert("Selecione pelo menos um jogo para excluir.");
            return;
        }

        $("#acao").val("E");
        $("#jogosJson").val(JSON.stringify(ids));
        $("#formAcao").submit();
    }
</script>