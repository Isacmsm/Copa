@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Jogadores";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}
@using System.Globalization;
@functions {

    private enum View
    {
        Index,
        New,
        Edit,
        EditAll
    }

    private class Jogador
    {

        public string IdJogador { get; set; }
        public string IdTime { get; set; }
        public string NomeTime { get; set; }
        public string Nome { get; set; }
        public decimal Salario { get; set; }
        public bool Capitao { get; set; }
        public bool Tecnico { get; set; }
        public bool Suspenso { get; set; }

    }

    private class Time
    {
        public string IdTime { get; set; }
        public string Nome { get; set; }

    }

    List<Botao> botoes = null;
    string idTime = null;
    string acao = null;
    string idJogador = null;
    Jogador jogador = null;
    View view = View.Index;
    List<Jogador> jogadores = null;
    List<Time> times = null;
    string idCapitao = null;
    string idTecnico = null;
    string idsSuspenso = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecaNulo(Request.Form["acao"]);
        idJogador = Util.ChecaNulo(Request.Form["idJogador"]);
        idTime = Util.ChecaNulo(Request.Form["idTime0"]);
        botoes = new BotaoDao().GetAll();
        idCapitao = Util.ChecaNulo(Request.Form["capitao"]);
        idTecnico = Util.ChecaNulo(Request.Form["tecnico"]);
        idsSuspenso = Util.ChecaNulo(Request.Form["idsSuspenso"]);
        

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }

    }

    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }

    //Metodo invocado após a manutenção paral limpar os valores das variáveis que estão na memoria do servidor.
    private void LimparVariaveis()
    {
        acao = null;
        idJogador = null;
        jogador = null;
        idTime = null;
    }

    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@Tipo", 1);
        parametros.Add("@IdJogador", idJogador);
        parametros.Add("@IdTime", idTime);

        jogadores = new Dao().ExecutarAcaoList<Jogador>("C", parametros);
    }


    private void ConsultaTime()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@Tipo", 2);

        times = new Dao().ExecutarAcaoList<Time>("C", parametros);
    }



    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdJogador", idJogador);
        parametros.Add("@IdTime", jogador.IdTime);
        parametros.Add("@Nome", jogador.Nome);
        parametros.Add("@Salario", jogador.Salario);
        parametros.Add("@Tipo", 1);

        new Dao().ExecutarAcao(acao, parametros);

    }

    private void ManutencaoEditAll()
    {


        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdTime", idTime);
        parametros.Add("@IdCapitao", idCapitao);
        parametros.Add("@IdTecnico", idTecnico);
        parametros.Add("@IdsSuspensos", idsSuspenso);
        parametros.Add("@Tipo", 2);

        new Dao().ExecutarAcao(acao, parametros);
    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && jogadores != null && jogadores.Count == 1)
        {
            jogador = jogadores.FirstOrDefault();
        }
    }




}

@{
    AlimentaVariaveis();



    if ((acao == "I" || acao == "A" || acao == "E") && view != View.EditAll)
    {
        Util.ExceptionHandler(() =>
        {
            jogador = new Jogador()
            {
                IdJogador = Util.ChecaNulo(Request.Form["idJogador"]),
                IdTime = Util.ChecaNulo(Request.Form["idTime"]),
                Nome = Util.ChecaNulo(Request.Form["nome"]),
                Salario = decimal.Parse(Util.ChecaNulo(Request.Form["salario"]), NumberStyles.Any, CultureInfo.InvariantCulture)
            };
            Manutencao();
            LimparVariaveis();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
            view = View.Index;
        }, this.ModelState);
    }
    else if (acao == "A" && view == View.EditAll)
    {
        Util.ExceptionHandler(() =>
        {
            ManutencaoEditAll();
            LimparVariaveis();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
            view = View.Index;
        }, this.ModelState);
    }

    Util.ExceptionHandler(() =>
    {
        Consultar();
        CarregarDados();

    }, this.ModelState);


    Util.ExceptionHandler(ConsultaTime, this.ModelState);

    if (jogador == null)
    {
        jogador = new Jogador();
    }

    if (view == View.EditAll && idJogador != null)
    {
        idJogador = null;
    }


}

@section head {

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        .form-check-input:checked {
            background-color: #dc3545;
            border-color: #dc3545;
        }

        .form-check-input:focus {
            box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
            border-color: #dc3545;
        }
    </style>
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idJogador" id="idJogador" value="@idJogador" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">

            <div class="row g-3">
                <div>
                    @RenderPage("~/AreaRestrita/Menu.cshtml")
                </div>
                <div>
                    <h1>Jogadores</h1>
                </div>

                @if (view == View.Edit || view == View.New)
                {

                    <div class="col-12 mb-3">
                        @PageHelper.MakeAlert()
                    </div>

                    <div class="col-md-4">
                        <input class="form-control @IsInvalid("nome")" placeholder="Nome" type="text" name="nome" id="nome" value="@jogador.Nome" />
                        @PageHelper.MakeFeedBack("nome")
                    </div>

                    <div class="col-md-4">
                        <select class="form-select @IsInvalid("idtime")" name="idTime" id="idTime">

                            <option value="">
                                Selecione um Time
                            </option>
                            @foreach (Time item in times)
                            {
                                <option @(item.IdTime == jogador.IdTime ? "selected" : "") value="@item.IdTime">
                                    @item.Nome
                                </option>
                            }
                        </select>
                        @PageHelper.MakeFeedBack("idtime")
                    </div>

                    <div class="col-md-4">
                        <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()"><i class="bi bi-eraser"></i> Limpar</button>
                    </div>

                    <div class="col-md-8">
                        <input class="form-control @IsInvalid("salario") money" placeholder="Salario" type="text" name="salario" id="salario" value="@jogador.Salario.ToString("F2", CultureInfo.InvariantCulture)" />
                        @PageHelper.MakeFeedBack("salario")
                    </div>
                }


                @if (view == View.EditAll)
                {
                    <div class="col-md-4">
                        <select class="form-select" name="idTime0" id="idTime0" onchange="selecionarConsulta()">

                            <option value="">
                                Selecione um Time
                            </option>
                            @foreach (Time item in times)
                            {
                                <option @(item.IdTime == idTime ? "selected" : "") value="@item.IdTime">
                                    @item.Nome
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()"><i class="bi bi-eraser"></i> Limpar</button>
                    </div>
                }

                @if (view == View.EditAll && idTime != null && jogadores != null)
                {
                    <div class="col-12 mb-5">
                        @PageHelper.MakeBotao(botoes, "A")
                    </div>
                }




                @if (view == View.Index)
                {
                    if (botoes.Any(x => x.Codigo == "I" || x.Codigo == "A"))
                    {
                        <div class="col-md-4 mb-3">
                            @if (botoes.Any(x => x.Codigo == "I"))
                            {
                                <button class="btn btn-primary btn-sm" type="submit" onclick="novo()"><i class="bi bi-file-earmark-plus"></i> Novo</button>
                            }

                            @if (botoes.Any(x => x.Codigo == "A"))
                            {

                                <button class="btn btn-warning btn-sm" type="submit" onclick="editAll()"><i class="bi bi-pencil-square"></i> Editar Funções/Suspenções</button>
                            }
                        </div>
                    }
                }


                @if (view == View.New || view == View.Edit)
                {
                    <div class="col-12 mb-5">
                        @if (view == View.New)
                        {
                            @PageHelper.MakeBotao(botoes, "I")

                        }
                        @if (view == View.Edit)
                        {
                            @PageHelper.MakeBotao(botoes, "A")
                            @PageHelper.MakeBotao(botoes, "E")
                        }
                    </div>
                }
            </div>

            @if (view == View.Index)
            {

                if (jogadores != null)
                {
                    <div>
                        <table class="table table-striped rounded mb-0">
                            <colgroup>
                                <col style="width: 15%" />
                                <col style="width: 23%" />
                                <col style="width: 23%" />
                                <col style="width: 23%" />
                                <col style="width: 15%" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="text-center align-middle">Id</th>
                                    <th>Nome do Time</th>
                                    <th>Nome</th>
                                    <th>Salario</th>
                                    <th class="text-center align-middle"></th>
                                </tr>
                            </thead>
                            <tbody class="table-group-divider">
                                @foreach (Jogador item in jogadores)
                                {
                                    <tr>
                                        <td class="text-center align-middle">#@item.IdJogador</td>
                                        <td>@item.NomeTime</td>
                                        <td class="@(item.Suspenso ? "text-danger text-decoration-line-through" : "")">
                                            @if (item.Capitao)
                                            {<i class="bi bi-star-fill text-warning"></i>}

                                            @if (item.Tecnico)
                                            {<i class="bi bi-person-badge text-info"></i>}

                                            @if (item.Suspenso)
                                            {<i class="bi bi-person-fill-dash"></i>}
                                            @item.Nome
                                        </td>
                                        <td>R$ @item.Salario.ToString("N2", new CultureInfo("pt-BR"))</td>

                                        <td class="text-center align-middle">
                                            @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                            {
                                                <button class="btn btn-warning btn-sm" type="button" onclick="editar('@item.IdJogador')"><i class="bi bi-pencil-square"></i> Editar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            }
            @if (view == View.EditAll && idTime != null)
            {

                if (jogadores != null)
                {
                    <div>
                        <table class="table table-striped rounded mb-0">
                            <colgroup>
                                <col style="width: 25%" />
                                <col style="width: 25%" />
                                <col style="width: 25%" />
                                <col style="width: 25%" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="text-center align-middle">Nome</th>
                                    <th class="text-center align-middle">Capitao</th>
                                    <th class="text-center align-middle">Tecnico</th>
                                    <th class="text-center align-middle">Suspenso</th>
                                </tr>
                            </thead>
                            <tbody class="table-group-divider">
                                @foreach (Jogador item in jogadores)
                                {
                                    <tr>
                                        <td class="text-center align-middle">@item.Nome</td>
                                        <td class="text-center align-middle"><input type="radio" name="capitao" value="@item.IdJogador" @(item.Capitao ? "checked" : "") /></td>
                                        <td class="text-center align-middle"><input type="radio" name="Tecnico" value="@item.IdJogador" @(item.Tecnico ? "checked" : "") /></td>
                                        <td class="text-center align-middle">

                                            <div class="form-check form-switch d-flex justify-content-center">
                                                <input class="form-check-input" type="checkbox" role="switch" name="idsSuspenso" value="@item.IdJogador" @(item.Suspenso ? "checked" : "")>
                                            </div>
                                        </td>



                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            }


        </div>
    </form>

    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function editar(idJogador) { // recebe as informações do html, ao capturar o evento onclick, e altera o estado do html do forms para ser depois capturado pelo servidor
            document.form1.idJogador.value = idJogador;
            document.form1.view.value = "@((int)View.Edit)";
            executarAcao("C")
        }

        function novo() {
            document.form1.view.value = "@((int)View.New)";
            document.form1.submit();
        }

        function editAll() {
            document.form1.view.value = "@((int)View.EditAll)";
            document.form1.submit();
        }

        function selecionarConsulta() {
            document.form1.submit();
        }
    </script>


</body>


