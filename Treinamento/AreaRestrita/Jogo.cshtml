@{
    Page.Title = "Jogos";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {

    private enum View
    {
        Index,
        New,
        Edit
    }
    private class Jogo
    {
        public string IdJogo { get; set; }
        public string IdTime1 { get; set; }
        public string Time1 { get; set; }
        public string IdTime2 { get; set; }
        public string Time2 { get; set; }
        public string Placar1 { get; set; }
        public string Placar2 { get; set; }
    }

    private class Time
    {
        public string IdTime { get; set; }
        public string Nome { get; set; }
    }

    string acao = null;
    string idJogo = null;
    string idTime1 = null;
    string idTime2 = null;
    View view = View.Index;

    List<Jogo> jogos = new List<Jogo>();
    List<Time> times = new List<Time>();

    private void AlimentaVariaveis()
    {
        acao = Util.ChecarNulo(Request.Form["acao"]);
        idJogo = Util.ChecarNulo(Request.Form["idJogo"]);
        idTime1 = Util.ChecarNulo(Request.Form["times1"]);
        idTime2 = Util.ChecarNulo(Request.Form["times2"]);

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }

    }
    private void LimpaVariaveis()
    {
        acao = null;
        idJogo = null;
        idTime1 = null;
        idTime2 = null;
    }
    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdJogo", idJogo);

        string procedure = GetNomeProcedure("C");

        Dao dao = new Dao();
        jogos = dao.ExecutarProcedureList<Jogo>(procedure, parametros);
    }
    private void ConsultarTimes()
    {
        string procedure = GetNomeProcedure("C");
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", "1");

        Dao dao = new Dao();
        times = dao.ExecutarProcedureList<Time>(procedure, parametros);
    }

    private string GetNomeProcedure(string acao)
    {
        switch (acao)
        {
            case "C": return "stp_Das_Jogo_Sel";
            case "I": return "stp_Das_Jogo_Ins";
            case "A": return "stp_Das_Jogo_Upd";
            case "E": return "stp_Das_Jogo_Del";
            default: return null;
        }
    }
    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdJogo", idJogo);
        parametros.Add("@IdTime1", idTime1);
        parametros.Add("@IdTime2", idTime2);

        string procedure = GetNomeProcedure(acao);

        Dao dao = new Dao();
        dao.ExecutarProcedure(procedure, parametros);

    }

    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && jogos != null && jogos.Count == 1)
        {
            Jogo jogo = jogos.FirstOrDefault();
            idJogo = jogo.IdJogo;
            idTime1 = jogo.IdTime1;
            idTime2 = jogo.IdTime2;
        }
    }

}

@{

    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            Manutencao();

            view = View.Index;

            LimpaVariaveis();

        }, this.ModelState);

    }

    Util.ExceptionHandler(() =>
    {
        ConsultarTimes();
        Consultar();

        CarregarDados();

    }, this.ModelState);
}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idJogo" id="idJogo" value="@idJogo" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">
            @RenderPage("~/AreaRestrita/Menu.cshtml")

            <h1>Jogos</h1>

            @PageHelper.MakeAlert()

            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>

            @if (view == View.Index)
            {
                <button class="btn btn-secondary" type="button" onclick="novo()">Novo</button>
            }

            @if (view == View.New)
            {
                <button class="btn btn-secondary" type="button" onclick="executaAcao('I')">Incluir</button>
            }

            @if (view == View.Edit)
            {
                <button class="btn btn-secondary" type="button" onclick="executaAcao('E')">Excluir</button>
                <button class="btn btn-secondary" type="button" onclick="executaAcao('A')">Alterar</button>
            }

            @if (view == View.New || view == View.Edit)
            {
                <div class="mb-3">
                    <label class="form-label" for="times1">Time 1: </label>
                    <select class="form-control @IsInvalid("times1")" id="times1" name="times1">
                        <option value=""></option>
                        @if (times != null)
                        {
                            foreach (Time item in times)
                            {
                                <option value="@item.IdTime" @(item.IdTime == idTime1 ? "selected" : "")>@item.Nome</option>
                            }
                        }
                    </select>
                    @PageHelper.MakeFeedBack("times1")
                </div>

                <div class="mb-3">
                    <label class="form-label" for="times2">Time 2: </label>
                    <select class="form-control @IsInvalid("times2")" id="times2" name="times2">
                        <option value=""></option>
                        @if (times != null)
                        {
                            foreach (Time item in times)
                            {
                                <option value="@item.IdTime" @(item.IdTime == idTime2 ? "selected" : "" )>@item.Nome</option>
                            }
                        }
                    </select>
                    @PageHelper.MakeFeedBack("times2")
                </div>
            }

            @if (view == View.Index)
            {
                if (jogos != null)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Time 1</th>
                                <th>Time 2</th>
                                <th>Placar 1</th>
                                <th>Placar 2</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Jogo item in jogos)
                            {
                                <tr>
                                    <td>@item.Time1</td>
                                    <td>@item.Time2</td>
                                    <td>@item.Placar1</td>
                                    <td>@item.Placar2</td>
                                    <td><button class="btn btn-secondary" type="button" onclick="editar('@item.IdJogo')">Editar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }

        </div>
    </form>
    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function editar(idJogo) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idJogo.value = idJogo;
            executaAcao('C');
        }
        function novo() {
            document.form1.view.value = "@((int)View.New)";
            executaAcao('');
        }
    </script>
</body>


