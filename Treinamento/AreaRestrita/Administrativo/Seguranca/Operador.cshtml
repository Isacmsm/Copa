@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Operador";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {

    private enum View
    {
        Index,
        New,
        Edit
    }

    private class Operador
    {
        public string IdOperador { get; set; }
        public string CPF { get; set; }
        public string Nome { get; set; }
        public string Senha { get; set; }
        public string Confirmacao { get; set; }
        public bool Ativo { get; set; }
    }

    string acao = null;
    string idOperador = null;
    string cpf = null;
    string nome = null;
    string senha = null;
    string confirmacao = null;
    bool ativo = true;

    View view = View.Index;

    List<Operador> operadores = null;
    List<Botao> botoes = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecarNulo(Request.Form["acao"]);
        idOperador = Util.ChecarNulo(Request.Form["idOperador"]);
        cpf = Util.ChecarNulo(Request.Form["cpf"]);
        nome = Util.ChecarNulo(Request.Form["nome"]);
        senha = Util.ChecarNulo(Request.Form["senha"]);
        confirmacao = Util.ChecarNulo(Request.Form["confirmacao"]);

        ativo = (Request.Form["opcao"] == "ativo" ? true : false);

        botoes = new BotaoDao().GetAll();

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }
    }
    private void LimpaVariaveis()
    {
        acao = null;
        idOperador = null;
        cpf = null;
        nome = null;
        confirmacao = null;
        ativo = true;
    }

    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdOperador", idOperador);

        operadores = new Dao().ExecutarAcaoList<Operador>("C", parametros);
    }

    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdOperador", idOperador);
        parametros.Add("@CPF", cpf);
        parametros.Add("@Nome", nome);
        parametros.Add("@Senha", senha);
        parametros.Add("@Confirmacao", confirmacao);
        parametros.Add("@Ativo", ativo);

        new Dao().ExecutarAcao(acao, parametros);
    }
    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && operadores != null && operadores.Count == 1)
        {
            Operador operador = operadores.FirstOrDefault();
            idOperador = operador.IdOperador;
            cpf = operador.CPF;
            nome = operador.Nome;
            senha = operador.Senha;
            confirmacao = operador.Senha;
            ativo = operador.Ativo;
        }
    }
    public void GerarSenha()
    {
        string novaSenha = "";

        Random rand = new Random();

        for (int i = 0; i < 11; i++)
        {
            //gera um caractere aleatório entre caracteres especiais, números, letras maiusculas e minúsculas
            novaSenha += Convert.ToChar(rand.Next(33, 127));
        }
        senha = novaSenha;
    }
}
@{
    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            Manutencao();
            view = View.Index;
            LimpaVariaveis();

            ModelState.AddError("alert-success", "Operação realizada com sucesso");

        }, this.ModelState);
    }
    //else if (acao == "GS")
    //{
    //    GerarSenha();
    //    Response.Write(senha);
    //    Response.End();
    //}

    Util.ExceptionHandler(() =>
    {
        Consultar();

        CarregarDados();

    }, this.ModelState);

}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idOperador" id="idOperador" value="@idOperador" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">

            <div class="d-flex">
                @RenderPage("~/AreaRestrita/Menu.cshtml")
            </div>

            <div class="my-4">
                <h1>Operadores</h1>
            </div>

            @PageHelper.MakeAlert()

            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>

            @if (view == View.New)
            {
                @PageHelper.MakeBotao(botoes, "I");
            }

            @if (view == View.Edit)
            {
                @PageHelper.MakeBotao(botoes, "A");
                @PageHelper.MakeBotao(botoes, "E");
            }

            @if (view == View.New || view == View.Edit)
            {
                <div class=" mb-3">
                    <label class="form-label mt-3" for="cpf">CPF</label>
                    <input class="form-control @Util.IsInvalid(ModelState,"CPF")" type="text" name="cpf" id="cpf" value="@cpf" maxlength="11" />
                    @PageHelper.MakeFeedBack("cpf")

                    <label class="form-label mt-3" for="nome">Nome</label>
                    <input class="form-control @Util.IsInvalid(ModelState,"nome")" type="text" name="nome" id="nome" value="@nome" />
                    @PageHelper.MakeFeedBack("nome")


                    <label class="form-label mt-3" for="senha">Senha</label>
                    <input class="form-control @Util.IsInvalid(ModelState,"senha")" type="text" name="senha" id="senha" value="@senha" />
                    @PageHelper.MakeFeedBack("senha")
                    <button class="btn btn-secondary d-flex" type="button" onclick="gerarSenha()">Gerar Senha</button>

                    <label class="form-label mt-3" for="confirmacao">Confirmação</label>
                    <input class="form-control @Util.IsInvalid(ModelState,"confirmacao")" type="text" name="confirmacao" id="confirmacao" value="@confirmacao" />
                    @PageHelper.MakeFeedBack("confirmacao")

                    <div>
                        <input type="radio" id="ativo" name="opcao" value="ativo" @(ativo ? "checked" : "")>
                        <label class="form-label mt-3" for="ativo">Ativo</label>
                        <input type="radio" id="inativo" name="opcao" value="inativo" @(!ativo ? "checked" : "")>
                        <label class="form-label" for="inativo">Inativo</label>
                    </div>

                </div>
            }

            @if (view == View.Index)
            {
                if (botoes.Any(x => x.Codigo == "I"))
                {
                    <button class="btn btn-secondary" type="button" onclick="adicionarNovo()">Novo</button>
                }

                if (operadores != null)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>CPF</th>
                                <th>Nome</th>
                                <th>Ativo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Operador item in operadores)
                            {
                                <tr>
                                    <td>@item.CPF</td>
                                    <td>@item.Nome</td>
                                    <td>
                                        @(item.Ativo ? "Sim": "Não")
                                    </td>
                                    <td>
                                        @if (botoes.Any(x => x.Codigo == "A"))
                                        {
                                            <button class="btn btn-secondary" type="button" onclick="editar('@item.IdOperador')">Editar</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }

        </div>
    </form>
    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/Scripts.js"></script>
    <script>
        function editar(idOperador) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idOperador.value = idOperador;
            executaAcao('C');
        }
        function adicionarNovo() {
            document.form1.view.value = "@((int)View.New)";
            executaAcao('');
        }

        function gerarSenha(){
            $.ajax({
                method: "POST",
                url: "Operador.cshtml",
                data: { acao: "GS" }
            }).done(function (res) {
                $("#senha").val(res);
            });
        }

        function gerarSenha2() {
            var xhr = new XMLHttpRequest();
            xhr.open("POST", "OperadorAux.cshtml", true);
            xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
            xhr.onreadystatechange = function () {
                if (xhr.readyState === 4 && xhr.status === 200) {
                    var res = xhr.responseText;
                    document.getElementById("senha").value = res;
                }
            };
            xhr.send("acao=GS");
        }

    </script>
</body>



