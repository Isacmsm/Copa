@using System.Web.Script.Serialization;
@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Ações";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {
    private enum View
    {
        Index,
        New,
        Edit
    }

    private class Retorno
    {
        public string Id { get; set; }
        public string Caption { get; set; }
    }

    private class Sistema
    {
        public string Id { get; set; }
        public string Caption { get; set; }
    }

    private class Modulo
    {
        public string IdModulo { get; set; }
        public string CaptionModulo { get; set; }
    }

    private class Pagina
    {
        public string IdPagina { get; set; }
        public string CaptionPagina { get; set; }
    }

    string acao = null;
    string id = null;
    string tipoConsulta = null;

    string idSistema = null;
    string captionSistema = null;

    string idModulo = null;
    string captionModulo = null;

    string idPagina = null;
    string captionPagina = null;

    List<Sistema> sistemas = null;
    List<Modulo> modulos = null;
    List<Pagina> paginas = null;
    List<Retorno> retorno = null;

    private void AlimentaVariaveis()
    {
        idSistema = Util.ChecarNulo(Request.Form["sistema"]);
        idModulo = Util.ChecarNulo(Request.Form["modulo"]);
        idPagina = Util.ChecarNulo(Request.Form["pagina"]);
        tipoConsulta = Util.ChecarNulo(Request.Form["tipoConsulta"]);
        id = Util.ChecarNulo(Request.Form["id"]);
        acao = Util.ChecarNulo(Request.Form["acao"]);
    }
    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();

        parametros.Add("@Id", id);
        parametros.Add("@tipoConsulta", tipoConsulta);

        if (tipoConsulta is null)
        {
            sistemas = new Dao().ExecutarAcaoList<Sistema>("CL", parametros);

        }

    }
    private void ConsultarLista()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();

        parametros.Add("@tipoConsulta", tipoConsulta);
        parametros.Add("@Id", id);

        retorno = new Dao().ExecutarAcaoList<Retorno>("CL", parametros);

    }

    //private void CarregarDados()
    //{
    //    if (tipoConsulta is null)
    //    {
    //        Sistema sistema = sistemas.FirstOrDefault();
    //        idSistema = sistema.IdSistema;
    //        captionSistema = sistema.CaptionSistema;
    //    }
    //    else if (tipoConsulta == "2")
    //    {
    //        Modulo modulo = modulos.FirstOrDefault();
    //        idModulo = modulo.IdModulo;
    //        captionModulo = modulo.CaptionModulo;
    //    }
    //    else if (tipoConsulta == "3")
    //    {
    //        Pagina pagina = paginas.FirstOrDefault();
    //        idPagina = pagina.IdPagina;
    //        captionPagina = pagina.CaptionPagina;
    //    }
    //}


}
@{
    AlimentaVariaveis();

    if (acao == "CL")
    {
        ConsultarLista();
        Response.Write(new JavaScriptSerializer().Serialize(retorno));
        Response.End();
    }
    else
    {
        Consultar();
    }

}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="tipoConsulta" id="tipoConsulta" value="@tipoConsulta" />
        <input type="hidden" name="id" id="id" value="@id" />
        <input type="hidden" name="acao" id="acao" value="@acao" />

        <div class="container">

            <div class="d-flex">
                @RenderPage("~/AreaRestrita/Menu.cshtml")
            </div>

            <div class="my-4">
                <h1>Exercício Complementar</h1>
            </div>


            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>

            <div class="my-3">
                <label class="form-label" for="sistema">Sistema:</label>

                <select class="form-control" id="sistema" name="sistema" onchange="carregarCombo('2', this,'modulo')">
                    <option value=""></option>
                    @if (sistemas != null)
                    {
                        foreach (Sistema item in sistemas)
                        {
                            <option value="@item.Id" @(item.Id == idSistema ? "selected" : "")>@item.Caption</option>
                        }
                    }
                </select>

            </div>

            <div class="mt-3 mb-3">
                <label class="form-label" for="modulo">Módulo</label>
                <select class="form-control" id="modulo" name="modulo" onchange="carregarCombo('3', this, 'pagina')">
                </select>
            </div>

            <div class="mt-3 mb-3">
                <label class="form-label" for="pagina">Páginas</label>
                <select class="form-control" id="pagina" name="pagina" onchange="carregarCombo('4', this, '')">
                </select>
            </div>
        </div>
    </form>
    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/Scripts.js"></script>
    <script>

        function carregarCombo(tipoConsulta, eleAtual, eleCarregar) {

            $.ajax({
                method: "POST",
                url: "AcaoAux.cshtml",
                data: {
                    acao: "CL",
                    tipoConsulta: tipoConsulta,
                    id: eleAtual.value
                }
            }).done(function (retorno) {

                //var items = dataList.split(', '); // Divide a lista em itens

                //var select = $('#' + eleCarregar);
                //select.empty();

                ////adiciona um linha em branco
                //var option = $('<option>');
                //option.attr('value', '')
                //option.text('');
                //select.append(option);

                ////adiciona os dados
                //for (var i = 0; i < items.length; i++) {

                //    var parts = items[i].split(':');

                //    var option = $('<option>');
                //    option.attr('value', parts[0]);
                //    option.text(parts[1]);
                //    select.append(option);
                //}

                var select = $('#' + eleCarregar);
                select.empty();

                var pagina = $('#pagina');
                pagina.empty();

                //adiciona um linha em branco
                var option = $('<option>');
                option.attr('value', '')
                option.text('');
                select.append(option);

                var lista = JSON.parse(retorno);

                lista.forEach(function (item) {

                    var option = $('<option>');
                    option.attr('value', item.Id);
                    option.text(item.Caption);
                    select.append(option);

                });

            });
        }
    </script>
</body>











