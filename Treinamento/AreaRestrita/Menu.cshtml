<div>

    @if (paginas != null)
    {
        <div>
            <ul class="menu">

                <li class="parent"><a href="#>Início</a></li>

                @foreach (Pagina item in paginas)
                {
                    pagina = item.CodigoPagina;

                    if (item.CodigoSistema != sistema)
                    {
                        sistema = item.CodigoSistema;

                        @Html.Raw(inserirSistema(item.CaptionSistema));


                        if (item.CodigoModulo != modulo)
                        {
                            modulo = item.CodigoModulo;
                            if (tagModuloAberto)
                            {
                                @Html.Raw("</ul>");
                            }
                            else
                            {
                                tagModuloAberto = true;
                            }

                            @Html.Raw("<li class=\"parent\"><a href=#>" + item.CaptionModulo + "<span class=\"expand\">»</span></a><ul class=\"child\">");


                            @*@Html.Raw(inserirModulo1(item.CaptionModulo));*@

                            @Html.Raw(inserirPagina(sistema, modulo, pagina, item.CaptionPagina));

                        }
                        else
                        {

                            @Html.Raw(inserirPagina(sistema, modulo, pagina, item.CaptionPagina));
                        }
                    }
                    else
                    {
                        if (item.CodigoModulo != modulo)
                        {
                            modulo = item.CodigoModulo;
                            if (tagModuloAberto)
                            {
                                @Html.Raw("</ul></li>");
                            }
                            else
                            {
                                tagModuloAberto = true;
                            }

                            @Html.Raw("<li class=\"parent\"><a href=#>" + item.CaptionModulo + "<span class=\"expand\">»</span></a><ul class=\"child\">");

                            @Html.Raw(inserirPagina(sistema, modulo, pagina, item.CaptionPagina));
                        }
                        else
                        {
                            @Html.Raw(inserirPagina(sistema, modulo, pagina, item.CaptionPagina));
                        }
                    }
                }

                @Html.Raw("</ul></li></ul></li>")
                <li class="parent"><a href="~/ControleAcesso/Sair.cshtml">Sair</a></li>
            </ul>
        </div>

    }
</div>


