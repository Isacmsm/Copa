
@functions{

    private class Pagina
    {
        public string CodigoSistema { get; set; }
        public string CaptionSistema { get; set; }
        public string CodigoModulo { get; set; }
        public string CaptionModulo { get; set; }

        public string CodigoPagina { get; set; }
        public string CaptionPagina { get; set; }
    }

    List<Pagina> paginas = null;

    string sistema = null;
    string modulo = null;
    string pagina = null;
    string rota = null;
    string tagA = null;
    string href = null;
    string extensao = ".cshtml";

    bool tagSistemaAberto = false;
    bool tagModuloAberto = false;

    private void Consultar()
    {

        Identificacao identificacao = new Identificacao();

        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", "C_Menu");
        parametros.Add("@IdOperador", identificacao.IdOperador);


        paginas = new Dao().ExecutarProcedureList<Pagina>("stp_Das_MontaMenu", parametros);

    }

    private string inserirSistema(string captionSistema)
    {
        string ret = "";
        if (tagSistemaAberto)
        {
            ret = "</ul></li></ul></li>";
            tagSistemaAberto = false;
            tagModuloAberto = false;
        }
        else
        {
            tagSistemaAberto = true;
        }

        ret += $"<li class=\"parent\"><a href=#>{captionSistema}</a><ul class=\"child\">";
        return ret;

    }

    private string inserirModulo1(string captionModulo)
    {
        string ret = "";
        modulo = captionModulo;
        if (tagModuloAberto)
        {
            ret = "</ul>";
        }
        else
        {
            tagModuloAberto = true;
        }

        ret += "<li class=\"parent\"><a href=#>" + captionModulo + "<span class=\"expand\">»</span></a><ul class=\"child\">";

        return ret;

    }

    private string inserirModulo2(string captionModulo)
    {
        string ret = "";
        if (tagModuloAberto)
        {
            ret = "</ul></li>";
        }
        else
        {
            tagModuloAberto = true;
        }

        ret += "<li><a href=\"#\">" + captionModulo + "</a><ul>";
        return ret;

    }

    private string inserirPagina(string sistema, string modulo, string pagina, string captionPagina)
    {
        string ret = $"<li><a href=\"/AreaRestrita/{sistema}/{modulo}/{pagina}.cshtml\">{captionPagina}</a></li>";

        //string aux = "<a href=\"/AreaRestrita/copaDoMundo/cadastro/time.cshtml\">Time</a>";

        return ret;


    }

}

@{
    Consultar();
}

