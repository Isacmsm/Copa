

@functions{

    private class Historico
    {

        public string Pagina { get; set; }
        public string TipoOperacao { get; set; }
        public string UsuarioOperacao { get; set; }
        public string DataOperacao { get; set; }
    }

    private class Operador
    {
        public string Nome { get; set; }
        public string Cpf { get; set; }
    }



    List<Historico> historicos = new List<Historico>();
    string dataInicio = null;
    string dataFim = null;
    Exception exception = null;
    string idOperador = null;
    string tipoOperacao = null;
    Operador operador = null;

    private void AlimentarVariaveis()
    {
        dataInicio = Util.ChecaNulo(Request.QueryString["dataInicio"]);
        dataFim = Util.ChecaNulo(Request.QueryString["dataFim"]);
        idOperador = Util.ChecaNulo(Request.QueryString["idOperador"]);
        tipoOperacao = Util.ChecaNulo(Request.QueryString["tipoOperacao"]);
    }

    private void Consulta()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@DataInicio", string.IsNullOrWhiteSpace(dataInicio) ? (object)DBNull.Value : dataInicio);
        parametros.Add("@DataFim", string.IsNullOrWhiteSpace(dataFim) ? (object)DBNull.Value : dataFim);
        parametros.Add("@IdOperador", idOperador);
        parametros.Add("@TipoOperacao", tipoOperacao);
        parametros.Add("@TipoConsulta", "Principal");


        historicos = new Dao().ExecutarProcedureList<Historico>("stp_AcoesOperadorImprimir_Sel", parametros);
    }

    private void ConsultaOperador()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdOperador", idOperador);
        parametros.Add("@TipoConsulta", "Operador");

        operador = new Dao().ExecutarProcedureList<Operador>("stp_AcoesOperadorImprimir_Sel", parametros).FirstOrDefault();
    }




}

@{
    try
    {
        AlimentarVariaveis();
        ConsultaOperador();
        Consulta();

    }
    catch (Exception ex)
    {
        exception = ex;
    }

}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    @@media print {
        .card {
            border: 1px solid #dee2e6 !important;
            box-shadow: none !important;
        }

        .badge {
            border: 1px solid #000 !important;
            print-color-adjust: exact !important;
            -webkit-print-color-adjust: exact !important;
        }

        .table {
            width: 100% !important;
            page-break-inside: auto;
            border-collapse: collapse !important;
        }

        .table-responsive {
            overflow: visible !important;
            max-height: none !important;
            height: auto !important;
        }

        tr {
            page-break-inside: avoid;
        }

        thead {
            display: table-header-group;
        }

        tfoot {
            display: table-footer-group;
        }

        .bg-success, .bg-danger, .bg-warning {
            print-color-adjust: exact !important;
            -webkit-print-color-adjust: exact !important;
        }

        @@page {
            margin: 1cm;
        }
    }
</style>


@if (exception != null)
{
    <div class="alert alert-warning">@exception.Message</div>
}
else
{

    if (historicos != null && historicos.Count > 0)
    {
        <div class="container mt-3">
            <div class="card mb-3">
                <div class="card-header">
                    <h3 class="mb-0">Relatório de Ações do Operador</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-1">
                        Operador: #@idOperador - @(operador != null ? operador.Nome : "") | CPF: @(operador != null ? operador.Cpf : "")
                    </p>
                    <p class="text-muted mb-0">
                        Período: @(!string.IsNullOrWhiteSpace(dataInicio) ? dataInicio : "Início") a @(!string.IsNullOrWhiteSpace(dataFim) ? dataFim : "Hoje")
                    </p>
                </div>
            </div>
            <div class="card">
                <table class="table table-hover table-bordered table-striped card-table mb-0">
                    <thead>
                        <tr>
                            <th>Pagina</th>
                            <th>Tipo</th>
                            <th>Usuario</th>
                            <th>Data Operação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Historico h in historicos)
                        {
                            <tr>
                                <td>@h.Pagina</td>
                                <td>
                                    @if (@h.TipoOperacao == "I")
                                    {
                                        <span class="badge bg-success ">INSERT</span>
                                    }
                                    @if (@h.TipoOperacao == "D")
                                    {
                                        <span class="badge bg-danger">DELETE</span>
                                    }
                                    @if (@h.TipoOperacao == "U")
                                    {
                                        <span class="badge bg-warning text-dark">UPDATE</span>
                                    }
                                </td>
                                <td>@h.UsuarioOperacao</td>
                                <td>@h.DataOperacao</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-light">Nenhum registro encontrado</div>
    }

}