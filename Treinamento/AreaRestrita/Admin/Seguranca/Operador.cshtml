@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Operadores";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}


@functions {
    private enum View
    {
        Index,
        New,
        Edit
    }


    private class Operador
    {
        public string IdOperador { get; set; }
        public string Cpf { get; set; }
        public string Nome { get; set; }
        public string Senha { get; set; }

    }

    string senha = null;
    string acao = null;
    string idOperador = null;
    Operador operador = null;
    View view = View.Index;
    List<Operador> operadores = null;
    List<Botao> botoes = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecaNulo(Request.Form["acao"]);
        idOperador = Util.ChecaNulo(Request.Form["idOperador"]);
        botoes = new BotaoDao().GetAll();

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }
    }


    private void LimparVariaveis()
    {
        acao = null;
        idOperador = null;
        operador = null;

    }

    private void GerarSenha()
    {
        string minusculas = "abcdefghijklmnopqrstuvwxyz";
        string especiais = "!@#$%^&*()-_=+[{]};:'\",<.>/?\\|";
        string maiusculas = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        string numeros = "0123456789";
        string todosOsCaracteres = minusculas + maiusculas + especiais + numeros;
        List<char> senhalist = new List<char>();
        Random random = new Random();
        senhalist.Add(minusculas[random.Next(0, minusculas.Length)]);
        senhalist.Add(maiusculas[random.Next(0, maiusculas.Length)]);
        senhalist.Add(numeros[random.Next(0, numeros.Length)]);
        senhalist.Add(especiais[random.Next(0, especiais.Length)]);
        do
        {
            senhalist.Add(todosOsCaracteres[random.Next(0, todosOsCaracteres.Length)]);
        } while (senhalist.Count < 12);

        for (int i = 0; i < senhalist.Count; i++)
        {
            char temp;
            int j = random.Next(0, senhalist.Count);
            temp = senhalist[j];
            senhalist[j] = senhalist[i];
            senhalist[i] = temp;
        }

        senha = new string(senhalist.ToArray());
    }

    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdOperador", idOperador);

        operadores = new Dao().ExecutarAcaoList<Operador>("C", parametros);
    }




    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }

    private void Manutencao()
    {

        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdOperador", idOperador);
        parametros.Add("@CPF", operador.Cpf);
        parametros.Add("@NOME", operador.Nome);
        parametros.Add("@SENHA", operador.Senha);

        new Dao().ExecutarAcao(acao, parametros);

    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && operadores != null && operadores.Count == 1)
        {
            operador = operadores.FirstOrDefault();
        }
    }


}

@{
    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            operador = new Operador()
            {
                IdOperador = Util.ChecaNulo(Request.Form["idOperador"]),
                Cpf = Util.ChecaNulo(Request.Form["cpf"]),
                Nome = Util.ChecaNulo(Request.Form["nome"]),
                Senha = Util.ChecaNulo(Request.Form["senha"])
            };

            Manutencao();
            LimparVariaveis();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
            view = View.Index;
        }, this.ModelState);

    }

    if (acao == "SENHA")
    {
        GerarSenha();
        Response.Write(senha);
        Response.End();
    }

    Util.ExceptionHandler(() =>
    {
        Consultar();
        CarregarDados();
    }, this.ModelState);

    if (operador == null)
    {
        operador = new Operador();
    }






}

@section head {

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idOperador" id="idOperador" value="@idOperador" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">

            <div class="row g-3">
                <div>
                    @RenderPage("~/AreaRestrita/Menu.cshtml")
                </div>
                <div>
                    <h1>Operadores</h1>
                </div>


                @if (view == View.Edit || view == View.New)
                {
                    <div class="col-12 mb-3">
                        @PageHelper.MakeAlert()
                    </div>

                    <div class="col-md-4">
                        <label for="cpf" class="form-label">CPF</label>
                        <input class="form-control @IsInvalid("cpf")" placeholder="01234567890" type="text" name="cpf" id="cpf" value="@operador.Cpf" />
                        @PageHelper.MakeFeedBack("cpf")
                    </div>

                    <div class="col-md-4">
                        <label for="nome" class="form-label">Nome</label>
                        <input class="form-control @IsInvalid("nome")" placeholder="Zé Ninguém" type="text" name="nome" id="nome" value="@operador.Nome" />
                        @PageHelper.MakeFeedBack("nome")
                    </div>

                    <div class="col-md-4">
                        <div class="d-flex gap-2 align-items-start">
                            <div class="flex-grow-1">
                                <label for="senha" class="form-label">Senha</label>
                                <input class="form-control @IsInvalid("senha")" placeholder="senhaTeste123$" type="text" name="senha" id="senha" value="@operador.Senha" />
                                @PageHelper.MakeFeedBack("senha")
                            </div>
                            <button class="btn btn-outline-primary mt-auto" type="button" onclick="gerarSenha()">Gerar Senha</button>
                        </div>

                    </div>


                    <div class="col-12">
                        <label for="inputEndereco" class="form-label">Endereço</label>
                        <input type="text" class="form-control" id="inputEndereco" placeholder="Rua dos bobos, Nº0">
                    </div>
                    <div class="col-12">
                        <label for="inputComplemento" class="form-label">Complemento</label>
                        <input type="text" class="form-control" id="inputComplemento" placeholder="Apartamento, condominio ou referencia">
                    </div>
                    <div class="col-md-4">
                        <label for="inputCidade" class="form-label">Cidade</label>
                        <input type="text" class="form-control" id="inputCidade">
                    </div>
                    <div class="col-md-4">
                        <label for="inputBairro" class="form-label">Bairro</label>
                        <input type="text" class="form-control" id="inputBairro">
                    </div>
                    <div class="col-md-2">
                        <label for="inputEstado" class="form-label">Estado</label>
                        <input type="text" class="form-control" id="inputEstado">
                    </div>
                    <div class="col-md-2">
                        <label for="inputCEP" class="form-label">CEP</label>
                        <input type="text" class="form-control" id="inputCEP" onchange="buscarCEP()">
                    </div>




                    <div class="col-md-4">
                        <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()"><i class="bi bi-eraser-fill"></i> Limpar</button>
                    </div>

                }

                @if (view == View.Index)
                {
                    if (botoes.Any(x => x.Codigo == "I"))
                    {
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-primary btn-sm" type="submit" onclick="novo()"><i class="bi bi-file-earmark-plus"></i> Novo</button>
                        </div>
                    }
                }

                @if (view == View.New || view == View.Edit)
                {
                    <div class="col-12 mb-5">
                        @if (view == View.New)
                        {
                            @PageHelper.MakeBotao(botoes, "I")

                        }
                        @if (view == View.Edit)
                        {
                            @PageHelper.MakeBotao(botoes, "A")
                            @PageHelper.MakeBotao(botoes, "E")
                        }
                    </div>
                }
            </div>



            @if (view == View.Index)
            {

                if (operadores != null)
                {
                    <div>
                        <table class="table table-striped rounded mb-0">
                            <colgroup>
                                <col style="width: 10%" />
                                <col style="width: 35%" />
                                <col style="width: 35%" />
                                <col style="width: 10%" />
                                <col style="width: 10%" />
                            </colgroup>
                            <thead >
                                <tr>
                                    <th class="text-center align-middle" scope="col">Id</th>
                                    <th scope="col">CPF</th>
                                    <th scope="col">Nome</th>
                                    <th scope="col">Senha</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody class="table-group-divider">

                                @foreach (Operador item in operadores)
                                {
                                    <tr>
                                        <td class="text-center align-middle">#@item.IdOperador</td>
                                        <td>@item.Cpf</td>
                                        <td>@item.Nome</td>
                                        <td>@item.Senha</td>
                                        <td class="text-center align-middle">
                                            @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                            {
                                                <button class="btn btn-warning btn-sm" type="button" onclick="editar('@item.IdOperador')"><i class="bi bi-pencil-square"></i> Editar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            }


        </div>
    </form>

    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function editar(idOperador) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idOperador.value = idOperador;
            executarAcao('C');
        }

        function novo() {
            document.form1.view.value = "@((int)View.New)";
            document.form1.submit();
        }

        function gerarSenha() {
            $.ajax({
                method: "POST",
                url: "/AreaRestrita/Admin/Seguranca/Operador.cshtml",
                data: { acao: "SENHA"}
            }).done(function (res) {
                $("#senha").val(res)
            })
        }

        function buscarCEP() {
            var cep = $("#inputCEP").val()

            $.ajax({
                method: "GET",
                url: "https://viacep.com.br/ws/" + cep + "/json/"
            }).done(function (res) {
                $("#inputEstado").val(res.uf)
                $("#inputBairro").val(res.bairro)
                $("#inputCidade").val(res.localidade)
                $("#inputEndereco").val(res.logradouro)
            })
        }
    </script>


</body>


