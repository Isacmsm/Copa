@RenderPage("~/AreaRestrita/Seguranca.cshtml")

@{
    Page.Title = "Consulta Acessos";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@section head{
    <link href="~/Scripts/Style.css" rel="stylesheet" />
}

<body>
    <form name="form1" id="form1" method="post">
        <input type="hidden" name="acao" id="acao" />

        <div class="container">
            <div>
                @RenderPage("~/AreaRestrita/Menu.cshtml")
            </div>

            <h1 class="mb-4">Histórico de Acessos</h1>

            <label for="idOperador">Operador</label>
            <div class="row mb-3">
                <div class="col">
                    <input type="text" id="idOperador" name="idOperador" class="form-control" data-group="groupOperador" data-column="IdOperador" />
                </div>
                <div class="col-auto">
                    @PageHelper.MakeTresPontos("groupOperador", "Consulta de Operadores", "Informe o nome do operador", "Operador", null)
                </div>
                <div class="col">
                    <input type="text" id="nomeOperador" name="nomeOperador" class="form-control" data-group="groupOperador" data-column="Nome" readonly />
                </div>
            </div>

            <div id="secaoConsulta" style="display:none">
                <div>
                    Exibindo
                    <span id="span-infoPaginacaoInicio" class="text-primary"></span>
                    <span id="span-infoPaginacaoFim" class="text-primary"></span>
                    de
                    <span id="span-totalRegistros"></span>
                    registros
                </div>

                <div class="card mt-2">
                    <div class="p-2">
                        <div class="row">
                            <div class="col">
                                <div class="dropdown">
                                    <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" id="dropdownMenuButton" data-bs-toggle="dropdown">
                                        Data
                                    </button>
                                    <div class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                                        <div class="px-2">
                                            <label for="dataInicio">De</label>
                                            <input type="date" id="dataInicio" name="dataInicio" class="form-control form-control-sm" />

                                            <label for="dataFim">Até</label>
                                            <input type="date" id="dataFim" name="dataFim" class="form-control form-control-sm" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-auto d-flex gap-2 align-items-center">
                                <button type="button" name="limpar" id="limpar" class="btn btn-sm btn-outline-secondary">Limpar</button>
                                <button type="button" name="filtrar" id="filtrar" class="btn btn-sm btn-primary">Filtrar</button>
                                <select id="quantidadePorPagina" name="quantidadePorPagina" class="form-select form-select-sm">
                                    <option value="10">10 por página</option>
                                    <option value="20">20 por página</option>
                                    <option value="50">50 por página</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="resultado-tabela"></div>
                    <div class="card-footer">
                        <div id="paginacao" class="row justify-content-center">
                            <div class="col-auto">
                                <button type="button" id="btn-paginacaoPrimeiro" class="btn btn-outline-secondary js-mudarPagina" title="Ir para o primeiro" data-acao="PRIMEIRO" disabled>&lt;&lt;</button>
                            </div>
                            <div class="col-auto">
                                <button type="button" id="btn-paginacaoAnterior" class="btn btn-outline-secondary js-mudarPagina" title="Anterior" data-acao="ANTERIOR" disabled>&lt;</button>
                            </div>
                            <div class="col-auto">
                                Página
                            </div>
                            <div class="col-auto">
                                <select class="form-select js-mudarPagina" name="pagina" id="pagina"></select>
                            </div>
                            <div class="col-auto">
                                de <span id="quantidadeDePaginas"></span>
                            </div>
                            <div class="col-auto">
                                <button type="button" id="btn-paginacaoProximo" class="btn btn-outline-secondary js-mudarPagina" title="Próximo" data-acao="PROXIMO" disabled>&gt;</button>
                            </div>
                            <div class="col-auto">
                                <button type="button" id="btn-paginacaoUltimo" class="btn btn-outline-secondary js-mudarPagina" title="Ir para o último" data-acao="ULTIMO" disabled>&gt;&gt;</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">

                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="modal fade" id="modalAcoes" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Ações da Sessão</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="card mb-3">
                        <div class="card-body">
                            <p class="mb-1"><strong>Nome:</strong> <span id="modalOperadorNome"></span></p>
                            <p class="mb-0"><strong>CPF:</strong> <span id="modalOperadorCpf"></span></p>
                        </div>
                    </div>
                    <div class="resultado-acoes"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ===================== TRÊS PONTOS =====================
        function openSearch(obj) {
            if (!obj) return;
            var group = findGroup(obj);
            if (!group) return;
            var search = document.querySelector('[data-group="' + group + '"][class="search"]');
            if (!search) return;
            var card = search.querySelector(".search-card");
            if (!card) return;
            card.classList.add("show");
            initSearch(search);
        }

        function closeSearch(obj) {
            if (!obj) return;
            var group = findGroup(obj);
            if (!group) return;
            var search = document.querySelector('[data-group="' + group + '"][class="search"]');
            if (!search) return;
            var card = search.querySelector(".search-card");
            if (!card) return;
            card.classList.remove("show");
            initSearch(search);
        }

        function initSearch(search) {
            var chave = search.querySelector('[name="chave"]');
            if (!chave) return;
            chave.value = "";
            var resultado = search.querySelector('.resultado');
            if (!resultado) return;
            resultado.innerHTML = "";
        }

        function makeSearch(obj) {
            if (!obj) return;
            var group = findGroup(obj);
            if (!group) return;
            var search = document.querySelector('[data-group="' + group + '"][class="search"]');
            if (!search) return;

            var chave = search.querySelector('[name="chave"]').value;
            var tipoConsulta = search.getAttribute("data-tipo-consulta");
            var consultaComposta = null;
            if (search.getAttribute("data-consulta-composta")) {
                consultaComposta = document.getElementById(search.getAttribute("data-consulta-composta")).value;
            }
            var resultado = search.querySelector('.resultado');

            $.ajax({
                method: "POST",
                url: "/AreaRestrita/AuxConsulta.cshtml",
                dataType: "json",
                data: {
                    chave: chave,
                    tipoConsulta: tipoConsulta,
                    consultaComposta: consultaComposta
                }
            }).done(function (res) {
                if (res.length == 0) {
                    resultado.innerHTML = "<div>Nenhum registro encontrado</div>";
                } else {
                    resultado.innerHTML = populateTable(res);
                }
            });
        }

        function populateTable(json) {
            var columns = Object.keys(json[0]);
            var header = "<thead><tr>" + columns.map(function (r) { return "<th>" + r + "</th>"; }).join('') + "</tr></thead>";
            var body = "<tbody>" + json.map(function (r) {
                var row = "<tr onclick='fecharSearch(this)'>";
                columns.forEach(function (key) {
                    row += "<td data-column='" + key + "'>" + r[key] + "</td>";
                });
                row += "</tr>";
                return row;
            }).join('') + "</tbody>";
            return '<table class="table table-striped table-sm table-bordered table-hover mt-3">' + header + body + '</table>';
        }

        function fecharSearch(obj) {
            var group = findGroup(obj);
            if (!group) return;

            document.querySelectorAll('[data-group=' + group + ']').forEach(function (item) {
                if (item instanceof HTMLInputElement) {
                    item.value = obj.querySelector("[data-column=" + item.getAttribute("data-column") + "]").innerText;
                }
            });

            closeSearch(obj);

            // Ao selecionar operador, mostra a seção e consulta
            if (group === "groupOperador") {
                document.getElementById("secaoConsulta").style.display = "block";
                document.form1.pagina.value = 1;
                consultarItens();
            }
        }

        function findGroup(obj) {
            if (obj.classList.contains("search")) {
                return obj.getAttribute("data-group");
            }
            return findGroup(obj.parentElement);
        }

        // ===================== PAGINAÇÃO =====================
        function consultarItens() {
            var resultado = document.querySelector('.resultado-tabela');

            let quantidadePorPagina = document.form1.quantidadePorPagina.value;
            let pagina = document.form1.pagina.value;
            let dataInicio = document.form1.dataInicio.value;
            let dataFim = document.form1.dataFim.value;
            let idOperador = document.form1.idOperador.value;

            $.ajax({
                type: "POST",
                url: "ConsultaAcessosAux.cshtml",
                data: {
                    quantidadePorPagina: quantidadePorPagina,
                    pagina: pagina,
                    dataInicio: dataInicio,
                    dataFim: dataFim,
                    idOperador: idOperador
                },
                success: function (res) {
                    resultado.innerHTML = res;
                    const totalRegistros = parseInt(resultado.querySelector("#totalRegistros").innerText);
                    atualizarPaginacao(pagina, totalRegistros);
                },
                error: function (xhr) {
                    resultado.innerHTML = xhr.responseText;
                }
            });
        }

        function atualizarPaginacao(pagina, totalRegistros) {
            var infoPaginacaoInicio = document.querySelector("#span-infoPaginacaoInicio");
            var infoPaginacaoFim = document.querySelector("#span-infoPaginacaoFim");
            var infoTotalRegistros = document.querySelector("#span-totalRegistros");
            var infoQuantidadeDePaginas = document.querySelector("#quantidadeDePaginas");
            var quantidadePorPagina = parseInt(document.form1.quantidadePorPagina.value);
            var selectPaginas = document.querySelector("#pagina");

            let paginacaoInicio = 0;
            let paginacaoFim = 0;
            let quantidadeDePaginas = 0;

            if (totalRegistros == 0) {
                pagina = "";
            }

            if (totalRegistros > 0) {
                if (pagina == "") pagina = 1;
                paginacaoInicio = ((pagina - 1) * quantidadePorPagina) + 1;
                paginacaoFim = (pagina * quantidadePorPagina <= totalRegistros) ? pagina * quantidadePorPagina : totalRegistros;
                quantidadeDePaginas = (totalRegistros % quantidadePorPagina == 0) ? parseInt(totalRegistros / quantidadePorPagina) : parseInt(totalRegistros / quantidadePorPagina + 1);
            }

            infoPaginacaoInicio.innerHTML = '<b>' + paginacaoInicio + '</b>';
            infoPaginacaoFim.innerHTML = '<b>- ' + paginacaoFim + '</b>';
            infoTotalRegistros.innerHTML = '<b>' + totalRegistros + '</b>';
            infoQuantidadeDePaginas.innerHTML = quantidadeDePaginas;

            selectPaginas.innerHTML = "";
            for (var i = 1; i <= quantidadeDePaginas; i++) {
                var option = document.createElement("option");
                option.value = i;
                option.textContent = i;
                selectPaginas.appendChild(option);
            }
            selectPaginas.value = pagina;

            atualizarBotoes(pagina, quantidadeDePaginas);
        }

        function atualizarBotoes(pagina, quantidadeDePaginas) {
            var btnPrimeiro = document.querySelector("#btn-paginacaoPrimeiro");
            var btnAnterior = document.querySelector("#btn-paginacaoAnterior");
            var btnProximo = document.querySelector("#btn-paginacaoProximo");
            var btnUltimo = document.querySelector("#btn-paginacaoUltimo");

            if (pagina == "") {
                btnProximo.disabled = true; btnUltimo.disabled = true;
                btnAnterior.disabled = true; btnPrimeiro.disabled = true;
            } else if (pagina == 1) {
                btnAnterior.disabled = true; btnPrimeiro.disabled = true;
                btnProximo.disabled = (quantidadeDePaginas == 1); btnUltimo.disabled = (quantidadeDePaginas == 1);
            } else if (pagina == quantidadeDePaginas) {
                btnProximo.disabled = true; btnUltimo.disabled = true;
                btnAnterior.disabled = false; btnPrimeiro.disabled = false;
            } else {
                btnProximo.disabled = false; btnUltimo.disabled = false;
                btnAnterior.disabled = false; btnPrimeiro.disabled = false;
            }
        }

        function mudarPagina(acao) {
            var pagina = parseInt(document.form1.pagina.value);
            if (acao) {
                switch (acao) {
                    case "PROXIMO": pagina++; break;
                    case "ANTERIOR": pagina--; break;
                    case "PRIMEIRO": pagina = 1; break;
                    case "ULTIMO": pagina = parseInt(document.querySelector("#quantidadeDePaginas").innerText); break;
                }
                document.form1.pagina.value = pagina;
            }
            consultarItens();
        }

        // ===================== EVENTOS =====================
        function adicionarEventos() {
            Array.from(form1.querySelectorAll(".js-mudarPagina")).forEach(function (item) {
                if (item.tagName.toLowerCase() == "select") {
                    item.addEventListener("change", function () { mudarPagina(); });
                } else if (item.tagName.toLowerCase() == "button") {
                    item.addEventListener("click", function () { mudarPagina(item.getAttribute("data-acao")); });
                }
            });

            document.form1.querySelector("#quantidadePorPagina").addEventListener("change", function () {
                document.form1.pagina.value = 1;
                consultarItens();
            });

            document.getElementById("filtrar").addEventListener("click", function () {
                document.form1.pagina.value = 1;
                consultarItens();
            });

            document.getElementById("limpar").addEventListener("click", function () {
                document.form1.pagina.value = 1;
                document.form1.dataInicio.value = "";
                document.form1.dataFim.value = "";
                consultarItens();
            });

            document.querySelector(".resultado-tabela").addEventListener("click", function (e) {
                var tr = e.target.closest("tbody tr");
                if (!tr) return;

                var idSessao = tr.querySelector("td:first-child").innerText;
                var idOperador = tr.getAttribute("data-idOperador");

                consultarAcoes(idSessao, idOperador);
            });

        }
        // ===================== CONSULTA MODAL =====================
        var modal = new bootstrap.Modal(document.getElementById('modalAcoes'));
        function consultarAcoes(idSessao, idOperador) {
            var resultadoAcoes = document.querySelector(".resultado-acoes");

            $.ajax({
                type: "POST",
                url: "ConsultaAcoesAux.cshtml",
                data: {
                    idSessao: idSessao,
                    idOperador: idOperador
                },
                success: function (res) {
                    resultadoAcoes.innerHTML = res;

                    var cpf = resultadoAcoes.querySelector("#operadorCpf");
                    var nome = resultadoAcoes.querySelector("#operadorNome");

                    document.getElementById("modalOperadorCpf").innerText = cpf ? cpf.innerText : "";
                    document.getElementById("modalOperadorNome").innerText = nome ? nome.innerText : "";

                    modal.show();
                },
                error: function (xhr) {
                    resultadoAcoes.innerHTML = xhr.responseText;
                }
            });
        }

        function init() {
            adicionarEventos();
        }

        init();
    </script>
</body>