@{
    Page.Title = "Modulos";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {
    private enum View
    {
        Index,
        New,
        Edit
    }

    private class Modulo
    {

        public string IdModulo { get; set; }
        public string IdSistema { get; set; }
        public string NomeSistema { get; set; }
        public string Caption { get; set; }
        public string Codigo { get; set; }

    }

    private class Sistema
    {

        public string IdSistema { get; set; }
        public string Codigo { get; set; }
        public string Caption { get; set; }

    }

    string acao = null;
    string idModulo = null;
    Modulo modulo = null;
    View view = View.Index;
    List<Modulo> modulos = null;
    List<Sistema> sistemas = null;
    List<Botao> botoes = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecaNulo(Request.Form["acao"]);
        idModulo = Util.ChecaNulo(Request.Form["idModulo"]);
        botoes = new BotaoDao().GetAll();

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }

    }

    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }

    //Metodo invocado após a manutenção paral limpar os valores das variáveis que estão na memoria do servidor.
    private void LimparVariaveis()
    {
        acao = null;
        idModulo = null;
        modulo = null;
    }

    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@Tipo", 1);
        parametros.Add("@IdModulo", idModulo);

        modulos = new Dao().ExecutarAcaoList<Modulo>("C", parametros);
    }


    private void ConsultaSistema()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@Tipo", 2);

        sistemas = new Dao().ExecutarAcaoList<Sistema>("C", parametros);
    }


    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdModulo", idModulo);
        parametros.Add("@IdSistema", modulo.IdSistema);
        parametros.Add("@Codigo", modulo.Codigo);
        parametros.Add("@Caption", modulo.Caption);

        new Dao().ExecutarAcao(acao, parametros);

    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && modulos != null && modulos.Count == 1)
        {
            modulo = modulos.FirstOrDefault();
        }
    }




}

@{
    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            modulo = new Modulo()
            {
                IdModulo = Util.ChecaNulo(Request.Form["idModulo"]),
                IdSistema = Util.ChecaNulo(Request.Form["idSistema"]),
                Codigo = Util.ChecaNulo(Request.Form["codigo"]),
                Caption = Util.ChecaNulo(Request.Form["caption"])
            };

            Manutencao();
            LimparVariaveis();
            ModelState.AddError("alert-success", "Operação realizada com sucesso");
            view = View.Index;
        }, this.ModelState);
    }

    Util.ExceptionHandler(() =>
    {
        Consultar();
        CarregarDados();

    }, this.ModelState);


    Util.ExceptionHandler(ConsultaSistema, this.ModelState);

    if (modulo == null)
    {
        modulo = new Modulo();
    }


}

@section head {

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idModulo" id="idModulo" value="@idModulo" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        <div class="container">

            <div class="row g-3">
                <div>
                    @RenderPage("~/AreaRestrita/Menu.cshtml")
                </div>
                <div>
                    <h1>Modulos</h1>
                </div>

                @if (view == View.Edit || view == View.New)
                {

                    <div class="col-12 mb-3">
                        @PageHelper.MakeAlert()
                    </div>

                    <div class="col-md-4">
                        <select class="form-select @IsInvalid("idsistema")" name="idSistema" id="idSistema">

                            <option value="">
                                Selecione um Sistema
                            </option>
                            @foreach (Sistema item in sistemas)
                            {
                                <option @(item.IdSistema == modulo.IdSistema ? "selected" : "") value="@item.IdSistema">
                                    @item.Caption
                                </option>
                            }
                        </select>
                        @PageHelper.MakeFeedBack("idsistema")
                    </div>

                    <div class="col-md-4">
                        <input class="form-control @IsInvalid("codigo")" placeholder="Codigo" type="text" name="codigo" id="codigo" value="@modulo.Codigo" />
                        @PageHelper.MakeFeedBack("codigo")
                    </div>

                    <div class="col-md-4">
                        <input class="form-control @IsInvalid("caption")" placeholder="Caption" type="text" name="caption" id="caption" value="@modulo.Caption" />
                        @PageHelper.MakeFeedBack("caption")
                    </div>

                    <div class="col-md-4">
                        <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()"><i class="bi bi-eraser"></i> Limpar</button>
                    </div>
                }





                @if (view == View.Index)
                {
                    if (botoes.Any(x => x.Codigo == "I"))
                    {
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-primary btn-sm" type="submit" onclick="novo()"><i class="bi bi-file-earmark-plus"></i> Novo</button>
                        </div>
                    }
                }


                @if (view == View.New || view == View.Edit)
                {
                    <div class="col-12 mb-5">
                        @if (view == View.New)
                        {
                            @PageHelper.MakeBotao(botoes, "I")

                        }
                        @if (view == View.Edit)
                        {
                            @PageHelper.MakeBotao(botoes, "A")
                            @PageHelper.MakeBotao(botoes, "E")
                        }
                    </div>
                }
            </div>

            @if (view == View.Index)
            {

                if (modulos != null)
                {
                    <div>
                        <table class="table table-striped rounded mb-0">
                            <colgroup>
                                <col style="width: 15%" />
                                <col style="width: 23%" />
                                <col style="width: 23%" />
                                <col style="width: 23%" />
                                <col style="width: 15%" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="text-center align-middle">Id</th>
                                    <th>Sistema</th>
                                    <th>Codigo</th>
                                    <th>Caption</th>
                                    <th class="text-center align-middle"></th>
                                </tr>
                            </thead>
                            <tbody class="table-group-divider">
                                @foreach (Modulo item in modulos)
                                {
                                    <tr>
                                        <td class="text-center align-middle">#@item.IdModulo</td>
                                        <td>@item.NomeSistema</td>
                                        <td>@item.Codigo</td>
                                        <td>@item.Caption</td>
                                        <td class="text-center align-middle">
                                            @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                            {
                                                <button class="btn btn-outline-dark btn-sm" type="button" onclick="editar('@item.IdModulo')"><i class="bi bi-pencil-square"></i> Editar</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            }


        </div>
    </form>

    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function editar(idModulo) { // recebe as informações do html, ao capturar o evento onclick, e altera o estado do html do forms para ser depois capturado pelo servidor
            document.form1.idModulo.value = idModulo;
            document.form1.view.value = "@((int)View.Edit)";
            executarAcao("C")
        }

        function novo() {
            document.form1.view.value = "@((int)View.New)";
            document.form1.submit();
        }
    </script>


</body>


