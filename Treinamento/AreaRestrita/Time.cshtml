@{
    Page.Title = "Times";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {

    private class Time
    {
        public string IdTime { get; set; }
        public string Nome { get; set; }
    }


    string acao = null;
    string idTime = null;
    string nome = null;

    List<Time> times = new List<Time>();


    private void AlimentaVariaveis()
    {
        acao = Util.ChecarNulo(Request.Form["acao"]);
        idTime = Util.ChecarNulo(Request.Form["idTime"]);
        nome = Util.ChecarNulo(Request.Form["nome"]);
    }
    private void LimpaVariaveis()
    {
        acao = null;
        idTime = null;
        nome = null;
    }

    private void Consultar()
    {

        string procedure = GetNomeProcedure("C");

        Dao dao = new Dao();
        times = dao.ExecutarProcedureList<Time>(procedure, null);

    }

    private string GetNomeProcedure(string acao)
    {
        switch (acao)
        {

            case "C": return "stp_Das_Time_Sel";
            case "I": return "stp_Das_Time_Ins";
            case "A": return "stp_Das_Time_UPD";
            case "E": return "stp_Das_Time_DEL";
            default: return null;
        }
    }
    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdTime", idTime);
        parametros.Add("@Nome", nome);

        string procedure = GetNomeProcedure(acao);

        Dao dao = new Dao();
        dao.ExecutarProcedure(procedure, parametros);

    }

    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }
}

@{

    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            Manutencao();
            LimpaVariaveis();

            ModelState.AddError("alert-success", "Operação realizada com sucesso");

        }, this.ModelState);

    }

    Util.ExceptionHandler(Consultar, this.ModelState);

}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idTime" id="idTime" value="@idTime" />

        <div class="container">
            @RenderPage("~/AreaRestrita/Menu.cshtml")

            <h1>Times</h1>

            @PageHelper.MakeAlert()

            <div class="mb-3">
                <label class="form-label" for="time">Time: </label>
                <input class="form-control @IsInvalid("nome")" type="text" name="nome" id="nome" value="@nome" />
                @PageHelper.MakeFeedBack("nome")

            </div>

            <button type="submit" onclick="estadoInicial()">Limpar</button>
            <button type="button" onclick="executaAcao('I')">Incluir</button>
            <button type="button" onclick="executaAcao('E')">Excluir</button>
            <button type="button" onclick="executaAcao('A')">Alterar</button>

            @if (times != null)
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>IdTime</th>
                            <th>Nome</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Time item in times)
                        {
                            <tr>
                                <td>@item.IdTime</td>
                                <td>@item.Nome</td>
                                <td><button type="button" onclick="editar('@item.IdTime','@item.Nome')">Editar</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </form>
    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function editar(idTime, nome) {
            document.form1.idTime.value = idTime;
            document.form1.nome.value = nome;
        }
    </script>
</body>


