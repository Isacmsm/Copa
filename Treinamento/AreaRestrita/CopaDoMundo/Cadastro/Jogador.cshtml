@RenderPage("~/AreaRestrita/Seguranca.cshtml")
@{
    Page.Title = "Jogadores";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {
    private enum View
    {
        Index,
        New,
        Edit,
        Configurar
    }
    private class Jogador
    {
        public string IdJogador { get; set; }
        public string NomeJogador { get; set; }
        public string IdTime { get; set; }
        public string NomeTime { get; set; }
        public decimal Salario { get; set; }
        public bool Titular { get; set; }
        public bool Capitao { get; set; }
        public bool Tecnico { get; set; }
        public bool Suspenso { get; set; }

    }

    private class Time
    {
        public string IdTime { get; set; }
        public string NomeTime { get; set; }
    }

    string acao = null;
    string idJogador = null;
    string nomeJogador = null;
    string idTime = null;
    string salario = null;
    bool titular = false;
    bool capitao = false;
    bool tecnico = false;
    bool suspenso = false;
    string tipoConsulta = null;
    string campoAlterado = null;

    View view = View.Index;

    List<Jogador> jogadores = null;
    List<Time> times = null;
    List<Botao> botoes = null;

    private void AlimentaVariaveis()
    {
        acao = Util.ChecarNulo(Request.Form["acao"]);
        idJogador = Util.ChecarNulo(Request.Form["idJogador"]);
        nomeJogador = Util.ChecarNulo(Request.Form["nomeJogador"]);
        salario = Util.ChecarNulo(Request.Form["salario"]);
        idTime = Util.ChecarNulo(Request.Form["times"]);
        titular = Request.Form["titular"] == "1";

        if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
        {
            view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
        }


        if (view == View.Configurar)
        {
            capitao = Request.Form["capitao" + idJogador] == "1";
            tecnico = Request.Form["tecnico" + idJogador] == "1";
            suspenso = Request.Form["suspenso" + idJogador] == "1";
        }
        else
        {
            capitao = Request.Form["capitao"] == "1";
            tecnico = Request.Form["tecnico"] == "1";
            suspenso = Request.Form["suspenso"] == "1";
        }

        tipoConsulta = Util.ChecarNulo(Request.Form["tipoConsulta"]);
        campoAlterado = Util.ChecarNulo(Request.Form["campoAlterado"]);

        botoes = new BotaoDao().GetAll();


    }
    private void LimpaVariaveis()
    {
        acao = null;
        idJogador = null;
        nomeJogador = null;
        idTime = null;
        salario = null;
        titular = false;
        capitao = false;
        tecnico = false;
        suspenso = false;
        tipoConsulta = null;
        campoAlterado = null;
    }

    private void Consultar()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdJogador", idJogador);
        parametros.Add("@IdTime", idTime);

        jogadores = new Dao().ExecutarAcaoList<Jogador>("C", parametros);
    }
    private void ConsultarTimes()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", "1");

        times = new Dao().ExecutarAcaoList<Time>("C", parametros);
    }

    private void Manutencao()
    {


        Dictionary<string, object> parametros = new Dictionary<string, object>();


        parametros.Add("@IdJogador", idJogador);
        parametros.Add("@Nome", nomeJogador);
        parametros.Add("@IdTime", idTime);

        if (salario != null)
        {
            parametros.Add("@Salario", salario.Replace(".", "").Replace(",", ".").ToString());
        }
        parametros.Add("@Titular", titular);
        parametros.Add("@Capitao", capitao);
        parametros.Add("@Tecnico", tecnico);
        parametros.Add("@Suspenso", suspenso);
        parametros.Add("@TipoConsulta", tipoConsulta);
        parametros.Add("@CampoAlterado", campoAlterado);

        new Dao().ExecutarAcao(acao, parametros);

    }

    private string IsInvalid(string key)
    {
        return (!ModelState.IsValidField(key) ? "is-invalid" : "");
    }
    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && jogadores != null && jogadores.Count == 1)
        {
            Jogador jogador = jogadores.FirstOrDefault();
            idJogador = jogador.IdJogador;
            nomeJogador = jogador.NomeJogador;
            idTime = jogador.IdTime;
            salario = jogador.Salario.ToString();
            titular = jogador.Titular;
            capitao = jogador.Capitao;
            tecnico = jogador.Tecnico;
            suspenso = jogador.Suspenso;
        }
    }
}

@{

    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            Manutencao();

            if (view != View.Configurar)
            {
                view = View.Index;
                LimpaVariaveis();
            }
            else
            {
                idJogador = null;
            }

            ModelState.AddError("alert-success", "Operação realizada com sucesso");
        }, this.ModelState);
    }

    Util.ExceptionHandler(() =>
    {
        ConsultarTimes();

        if (view != View.Configurar || view == View.Configurar && idTime != null)
        {
            Consultar();
        }

        CarregarDados();

    }, this.ModelState);
}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idJogador" id="idJogador" value="@idJogador" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />
        <input type="hidden" name="tipoConsulta" id="tipoConsulta" value="@tipoConsulta" />
        <input type="hidden" name="campoAlterado" id="campoAlterado" value="@campoAlterado" />

        <div class="container">

            <div class="d-flex">
                @RenderPage("~/AreaRestrita/Menu.cshtml")
            </div>
            <div class="my-4">
                <h1>Jogadores</h1>
            </div>

            @PageHelper.MakeAlert()

            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>

            @if (view == View.New)
            {
                @PageHelper.MakeBotao(botoes, "I");
            }

            @if (view == View.Edit)
            {
                @PageHelper.MakeBotao(botoes, "A");
                @PageHelper.MakeBotao(botoes, "E");
            }

            @if (view == View.Index)
            {
                <button class="btn btn-secondary" type="submit" onclick="configurar()">Configurar</button>
            }

            @if (view == View.New || view == View.Edit)
            {
                <div class="my-3">
                    <label class="form-label" for="jogador">Jogador: </label>
                    <input class="form-control @IsInvalid("nomeJogador")" type="text" name="nomeJogador" id="nomeJogador" value="@nomeJogador" />
                    @PageHelper.MakeFeedBack("nomeJogador")
                </div>
                <div class="mb-3">
                    <label class="form-label" for="times">Time: </label>
                    <select class="form-control @IsInvalid("times")" id="times" name="times">
                        <option value=""></option>
                        @if (times != null)
                        {
                            foreach (Time item in times)
                            {
                                <option value="@item.IdTime" @(item.IdTime == idTime ? "selected" : "")>@item.NomeTime</option>
                            }
                        }
                    </select>
                    @PageHelper.MakeFeedBack("times")
                </div>
                <div class="mb-3">
                    <label class="form-label" for="salario">Salário: </label>
                    <input class="form-control @IsInvalid("salarioJogador")" type="text" id="salario" name="salario" value="@salario" />
                </div>
                <div>
                    <input type="checkbox" id="titular" name="titular" value="1" @(titular ? "checked" : "")>
                    <label class="form-label">Titular</label>
                </div>
                <div>
                    <input type="checkbox" id="capitao" name="capitao" value="1" @(capitao ? "checked" : "")>
                    <label class="form-label">Capitão</label>
                </div>
                <div>
                    <input type="checkbox" id="tecnico" name="tecnico" value="1" @(tecnico ? "checked" : "")>
                    <label class="form-label">Técnico</label>
                </div>
                <div>
                    <input type="checkbox" id="suspenso" name="suspenso" value="1" @(suspenso ? "checked" : "")>
                    <label class="form-label">Suspenso</label>
                </div>
            }
            else if (view == View.Configurar)
            {
                <div class="mt-3 mb-3">
                    <label class="form-label" for="times">Time: </label>
                    <select class="form-control @IsInvalid("times")" id="times" name="times" onchange="configurar()">
                        <option value=""></option>
                        @if (times != null)
                        {
                            foreach (Time item in times)
                            {
                                <option value="@item.IdTime" @(item.IdTime == idTime ? "selected" : "")>@item.NomeTime</option>
                            }
                        }
                    </select>
                    @PageHelper.MakeFeedBack("times")
                </div>
                if (jogadores != null)
                {
                    <div>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Nome Jogador</th>
                                    <th>Capitão</th>
                                    <th>Técnico</th>
                                    <th>Supenso</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (Jogador item in jogadores)
                                {
                                    <tr>
                                        <td>@item.NomeJogador</td>
                                        <td>
                                            <input type="radio" id="capitao@(item.IdJogador)" name="idCapitao" value="@(item.IdJogador)" onchange="alterarConfiguracao('c',@item.IdJogador)" @(item.Capitao ? "checked" : "")>
                                        </td>
                                        <td>
                                            <input type="radio" id="tecnico@(item.IdJogador)" name="idTecnico" value="@(item.IdJogador)" onchange="alterarConfiguracao('t',@item.IdJogador)" @(item.Tecnico ? "checked" : "")>
                                        </td>
                                        <td>
                                            <input type="checkbox" id="suspenso@(item.IdJogador)" name="suspenso@(item.IdJogador)" value="1" onchange="alterarConfiguracao('s',@item.IdJogador)" @(item.Suspenso ? "checked" : "")>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            }

            @if (view == View.Index)
            {
                if (botoes.Any(x => x.Codigo == "I"))
                {
                    <button class="btn btn-secondary" type="button" onclick="adicionarNovo()">Novo</button>
                }

                if (jogadores != null)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Nome Jogador</th>
                                <th>Nome Time</th>
                                <th>Salário</th>
                                <th>Titular</th>
                                <th>Capitão</th>
                                <th>Técnico</th>
                                <th>Supenso</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Jogador item in jogadores)
                            {
                                <tr>
                                    <td>@item.NomeJogador</td>
                                    <td>@item.NomeTime</td>
                                    <td>@item.Salario.ToString("N2")</td>
                                    <td>
                                        @(item.Titular ? "Sim": "Não")
                                    </td>
                                    <td>
                                        @(item.Capitao ? "Sim": "Não")
                                    </td>
                                    <td>
                                        @(item.Tecnico ? "Sim": "Não")
                                    </td>
                                    <td>
                                        @(item.Suspenso ? "Sim": "Não")
                                    </td>
                                    <td>
                                        @if (botoes.Any(x => x.Codigo == "A"))
                                        {
                                            <button class="btn btn-secondary" type="button" onclick="editar('@item.IdJogador')">Editar</button>
                                        }
                                    </td>

                                </tr>
                            }
                        </tbody>


                    </table>
                }
            }

        </div>
    </form>
    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/Scripts.js"></script>
    <!-- jQuery -->
    <!--<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>-->
    <!-- jQuery Mask Plugin -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

    <script>
        function editar(idJogador) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idJogador.value = idJogador;
            executaAcao('C');
        }
        function configurar() {
            document.form1.view.value = "@((int)View.Configurar)";
            executaAcao('C');
        }
        function alterarConfiguracao(campoAlterado, idJogador) {
            document.form1.campoAlterado.value = campoAlterado;
            document.form1.tipoConsulta.value = '1';
            document.form1.idJogador.value = idJogador;
            executaAcao('A');
        }

        function adicionarNovo() {
            document.form1.view.value = "@((int)View.New)";
            executaAcao('');
        }

        $(document).ready(function () {
            $('#salario').mask('000.000.000,00', { reverse: true });
        });

    </script>
</body>