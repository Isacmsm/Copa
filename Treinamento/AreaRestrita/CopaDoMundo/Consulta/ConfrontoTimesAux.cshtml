@functions{

    string idTime1 = null;
    string idTime2 = null;
    string jogoIniciado = null;

    private void AlimentaVariaveis()
    {
        idTime1 = Util.ChecarNulo(Request.Form["idTime1"]);
        idTime2 = Util.ChecarNulo(Request.Form["idTime2"]);
        jogoIniciado = Util.ChecarNulo(Request.Form["jogoIniciado"]);
    }

    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();

        parametros.Add("@idTime1", idTime1);
        parametros.Add("@idTime2", idTime2);
        parametros.Add("@JogoIniciado", jogoIniciado);

        new Dao().ExecutarAcao("copaDoMundo", "consulta", "ConfrontoTimes", "A", parametros);
    }
}

@{

    AlimentaVariaveis();

    Util.ExceptionHandler(() =>
    {
        Manutencao();
        Response.Write("OK");

    }, this.ModelState);

    Response.End();

}