@{
    Page.Title = "Artilheiros";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {

    private class Artilharia
    {
        public string NomeTime { get; set; }
        public string Artilheiro { get; set; }
        public string GolsMarcados { get; set; }
    }

    List<Artilharia> artilharia = null;

    private void Consultar()
    {
        //artilharia = new Dao().ExecutarProcedureList<Artilharia>("stp_Das_Artilharia_Sel", null);
        artilharia = new Dao().ExecutarAcaoList<Artilharia>("C", null);
    }
}

@{

    Util.ExceptionHandler(() =>
    {
        Consultar();

    }, this.ModelState);

}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
}

<body>
    <form name="form1" method="post">

        <div class="container">

            @RenderPage("~/AreaRestrita/Menu.cshtml")

            <h1>Artilheiros</h1>

            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>

            @if (artilharia != null)
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Nome Time</th>
                            <th>Artilheiro</th>
                            <th>Gols Marcados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Artilharia item in artilharia)
                        {
                            <tr>
                                <td>@item.NomeTime</td>
                                <td>@item.Artilheiro</td>
                                <td>@item.GolsMarcados</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </form>
    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>