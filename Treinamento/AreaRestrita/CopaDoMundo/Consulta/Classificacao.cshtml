@{
    Page.Title = "Classificação";
    Layout = "~/AreaRestrita/_Layout.cshtml";
}

@functions {

    private class Classificacao
    {
        public string Time { get; set; }
        public string Pontuacao { get; set; }
        public string SaldoGols { get; set; }
        public string GolsMarcados { get; set; }
    }

    List<Classificacao> classificacao = null;

    private void Consultar()
    {
        Dao dao = new Dao();
        classificacao = dao.ExecutarProcedureList<Classificacao>("stp_Das_Classificacao_Sel", null);
    }
}

@{
    Util.ExceptionHandler(() =>
    {
        Consultar();

    }, this.ModelState);
}

@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
}

<body>
    <form name="form1" method="post">

        <div class="container">
            @RenderPage("~/AreaRestrita/Menu.cshtml")
            <h1>Classificação</h1>
            <button class="btn btn-secondary" type="submit" onclick="estadoInicial()">Limpar</button>
            @if (classificacao != null)
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Pontuação</th>
                            <th>Saldo de Gols</th>
                            <th>Gols Marcados</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Classificacao item in classificacao)
                        {
                            <tr>
                                <td>@item.Time</td>
                                <td>@item.Pontuacao</td>
                                <td>@item.SaldoGols</td>
                                <td>@item.GolsMarcados</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </form>
    <script src="~/Scripts/Scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>